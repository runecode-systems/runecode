{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/CapabilityManifest.schema.json",
  "title": "CapabilityManifest",
  "description": "Protocol-owned capability manifest family for run- and stage-scoped opt-ins. The scope, lifecycle identifiers, and shared principal identity are explicit so manifests never rely on implicit security-sensitive defaults.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "allOf": [
    {
      "if": {
        "properties": {
          "principal": {
            "properties": {
              "role_family": {
                "const": "workspace"
              }
            },
            "required": [
              "role_family"
            ]
          }
        },
        "required": [
          "principal"
        ]
      },
      "then": {
        "properties": {
          "principal": {
            "properties": {
              "role_kind": {
                "enum": [
                  "workspace-read",
                  "workspace-edit",
                  "workspace-test"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "principal": {
            "properties": {
              "role_family": {
                "const": "gateway"
              }
            },
            "required": [
              "role_family"
            ]
          }
        },
        "required": [
          "principal"
        ]
      },
      "then": {
        "properties": {
          "principal": {
            "properties": {
              "role_kind": {
                "enum": [
                  "model-gateway",
                  "auth-gateway",
                  "git-gateway",
                  "web-research",
                  "dependency-fetch"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manifest_scope": {
            "const": "stage"
          }
        },
        "required": [
          "manifest_scope"
        ]
      },
      "then": {
        "required": [
          "run_id",
          "stage_id"
        ]
      },
      "else": {
        "required": [
          "run_id"
        ],
        "not": {
          "required": [
            "stage_id"
          ]
        }
      }
    }
  ],
  "required": [
    "schema_id",
    "schema_version",
    "principal",
    "manifest_scope",
    "approval_profile",
    "capability_opt_ins",
    "allowlist_refs",
    "signatures"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.CapabilityManifest",
      "description": "Stable protocol object-family identifier for run or stage capability manifests.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.2.0",
      "description": "Exact protocol schema version used to validate this capability manifest.",
      "x-data-class": "public"
    },
    "principal": {
      "$ref": "PrincipalIdentity.schema.json",
      "description": "Shared principal identity for the run or stage this capability manifest governs.",
      "x-data-class": "sensitive"
    },
    "manifest_scope": {
      "type": "string",
      "enum": [
        "run",
        "stage"
      ],
      "description": "Scope of capability opt-ins covered by this manifest.",
      "x-data-class": "public"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Run identifier bound into the capability manifest so approvals and leases fail closed when the run changes.",
      "x-data-class": "sensitive"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Stage identifier required for stage-scoped capability manifests.",
      "x-data-class": "sensitive"
    },
    "approval_profile": {
      "type": "string",
      "enum": [
        "moderate"
      ],
      "description": "Approval profile selected as a signed manifest input for this capability manifest. MVP currently allows only the moderate profile.",
      "x-data-class": "public"
    },
    "capability_opt_ins": {
      "type": "array",
      "maxItems": 64,
      "description": "Explicit capability opt-ins enabled for the run or stage scope. An empty array is the intentional signed no-capabilities posture.",
      "x-data-class": "public",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "Stable capability identifier explicitly enabled by the manifest."
      },
      "uniqueItems": true
    },
    "allowlist_refs": {
      "type": "array",
      "maxItems": 64,
      "description": "Digest references to allowlist artifacts bound into the manifest signature input.",
      "x-data-class": "public",
      "items": {
        "$ref": "Digest.schema.json#/$defs/digestValue",
        "description": "Digest reference to an allowlist artifact consumed by this manifest."
      },
      "uniqueItems": true
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "description": "Detached signatures attesting to the exact capability manifest contents.",
      "x-data-class": "public",
      "items": {
        "$ref": "SignedObjectEnvelope.schema.json#/$defs/signatureBlock",
        "description": "Detached signature block for the manifest payload."
      }
    }
  }
}
