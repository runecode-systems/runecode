{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditRecordInclusionGetResponse.schema.json",
  "title": "AuditRecordInclusionGetResponse",
  "description": "Typed audit record inclusion response carrying independently checkable broker-owned derived inclusion material.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "inclusion"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.AuditRecordInclusionGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "inclusion": { "$ref": "AuditRecordInclusion.schema.json", "description": "Broker-projected audit record inclusion material.", "x-data-class": "public" }
  }
}
