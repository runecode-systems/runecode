{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionWatchRequest.schema.json",
  "title": "SessionWatchRequest",
  "description": "Typed session watch request with follow and snapshot semantics for transport-neutral live UX.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "request_id", "stream_id", "follow", "include_snapshot"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionWatchRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request identifier.", "x-data-class": "public" },
    "stream_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable stream identifier.", "x-data-class": "public" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional session identity filter.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional workspace scope filter.", "x-data-class": "public" },
    "status": { "type": "string", "enum": ["active", "completed", "archived"], "description": "Optional session status filter.", "x-data-class": "public" },
    "last_activity_kind": { "type": "string", "enum": ["session_created", "run_progress", "approval_pending", "artifact_recorded", "audit_recorded", "chat_message", "unknown"], "description": "Optional session activity-kind filter.", "x-data-class": "public" },
    "follow": { "type": "boolean", "description": "Whether to continue streaming new session updates.", "x-data-class": "public" },
    "include_snapshot": { "type": "boolean", "description": "Whether to include an initial session snapshot event before live updates.", "x-data-class": "public" }
  }
}
