{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionListRequest.schema.json",
  "title": "SessionListRequest",
  "description": "Typed session list request with explicit ordering and opaque cursor semantics.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionListRequest", "description": "Protocol schema identifier for SessionListRequest.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for SessionListRequest.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable caller request identity.", "x-data-class": "public" },
    "cursor": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Opaque continuation cursor.", "x-data-class": "public" },
    "limit": { "type": "integer", "minimum": 1, "maximum": 200, "description": "Requested page size.", "x-data-class": "public" },
    "order": { "type": "string", "enum": ["updated_at_desc", "updated_at_asc"], "description": "Explicit session ordering semantics.", "x-data-class": "public" }
  }
}
