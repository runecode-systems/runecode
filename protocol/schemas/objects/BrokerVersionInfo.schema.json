{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/BrokerVersionInfo.schema.json",
  "title": "BrokerVersionInfo",
  "description": "Broker version and build diagnostic contract for local API surfaces.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 21,
  "required": ["schema_id", "schema_version", "product_version", "build_revision", "build_time", "protocol_bundle_version", "protocol_bundle_manifest_hash", "api_family", "api_version", "supported_transport_encodings"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.BrokerVersionInfo", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "product_version": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Product semantic version.", "x-data-class": "public" },
    "build_revision": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Build revision string.", "x-data-class": "public" },
    "build_time": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Build time string.", "x-data-class": "public" },
    "protocol_bundle_version": { "type": "string", "minLength": 1, "maxLength": 32, "description": "Protocol bundle version.", "x-data-class": "public" },
    "protocol_bundle_manifest_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Protocol bundle manifest digest identity.", "x-data-class": "public" },
    "api_family": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Logical API family name.", "x-data-class": "public" },
    "api_version": { "type": "string", "minLength": 1, "maxLength": 32, "description": "Logical API version.", "x-data-class": "public" },
    "supported_transport_encodings": { "type": "array", "maxItems": 8, "description": "Supported transport encoding set.", "x-data-class": "public", "items": { "type": "string", "minLength": 1, "maxLength": 32, "description": "Supported encoding value.", "x-data-class": "public" } },
    "project_substrate_contract_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Canonical project-substrate contract identifier active at broker startup.", "x-data-class": "public" },
    "project_substrate_contract_version": { "type": "string", "minLength": 1, "maxLength": 32, "description": "Canonical project-substrate contract version active at broker startup.", "x-data-class": "public" },
    "project_substrate_version": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Repository-declared RuneContext substrate version active at broker startup, when parseable.", "x-data-class": "public" },
    "project_substrate_validation_state": { "type": "string", "enum": ["valid", "invalid", "missing"], "description": "Validation posture state for the active canonical project substrate.", "x-data-class": "public" },
    "project_substrate_posture": {
      "type": "string",
      "enum": [
        "missing",
        "invalid",
        "non_verified",
        "supported_current",
        "supported_with_upgrade_available",
        "unsupported_too_old",
        "unsupported_too_new"
      ],
      "description": "Compatibility posture for the active project substrate under this RuneCode release policy.",
      "x-data-class": "public"
    },
    "project_substrate_blocked_reasons": {
      "type": "array",
      "maxItems": 32,
      "description": "Stable reason-code set explaining blocked normal operation when posture is not supported.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Deterministic blocked reason code.", "x-data-class": "public" }
    },
    "project_substrate_supported_min": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Lowest supported repository substrate version for this RuneCode release.", "x-data-class": "public" },
    "project_substrate_supported_max": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Highest supported repository substrate version for this RuneCode release.", "x-data-class": "public" },
    "project_substrate_recommended": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Recommended repository substrate version target for this RuneCode release.", "x-data-class": "public" },
    "project_context_identity_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Project-context identity digest bound to validated canonical project-substrate snapshot.", "x-data-class": "public" }
    ,"project_substrate_posture_summary": {
      "$ref": "ProjectSubstratePostureSummary.schema.json",
      "description": "Summary RuneContext compatibility posture projected into broker version diagnostics.",
      "x-data-class": "public"
    }
  }
}
