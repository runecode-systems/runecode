{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalGetResponse.schema.json",
  "title": "ApprovalGetResponse",
  "description": "Typed approval detail response including optional signed request/decision artifacts.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "approval"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "approval": { "$ref": "ApprovalSummary.schema.json", "description": "Approval summary payload.", "x-data-class": "public" },
    "signed_approval_request": { "$ref": "SignedObjectEnvelope.schema.json", "description": "Optional signed ApprovalRequest envelope.", "x-data-class": "sensitive" },
    "signed_approval_decision": { "$ref": "SignedObjectEnvelope.schema.json", "description": "Optional signed ApprovalDecision envelope.", "x-data-class": "sensitive" }
  }
}
