{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderSetupSessionBeginResponse.schema.json",
  "title": "ProviderSetupSessionBeginResponse",
  "description": "Typed broker response for setup-session begin.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": ["schema_id", "schema_version", "request_id", "setup_session", "profile"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderSetupSessionBeginResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "setup_session": { "$ref": "ProviderSetupSession.schema.json", "description": "Broker-owned setup session record.", "x-data-class": "public" },
    "profile": { "$ref": "ProviderProfile.schema.json", "description": "Updated provider profile metadata.", "x-data-class": "public" }
  }
}
