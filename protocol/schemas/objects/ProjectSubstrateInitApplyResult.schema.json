{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateInitApplyResult.schema.json",
  "title": "ProjectSubstrateInitApplyResult",
  "description": "Typed result for explicit project-substrate initialization apply.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "repository_root", "status", "current_snapshot", "resulting_snapshot", "preview_token"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateInitApplyResult", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "repository_root": { "type": "string", "minLength": 1, "maxLength": 4096, "description": "Authoritative repository root for initialization apply.", "x-data-class": "public" },
    "status": { "type": "string", "enum": ["noop", "applied", "blocked", "applied_validation_failed"], "description": "Initialization apply status.", "x-data-class": "public" },
    "reason_codes": {
      "type": "array",
      "maxItems": 32,
      "description": "Stable reason codes when apply is blocked or post-apply validation failed.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Deterministic apply reason code.", "x-data-class": "public" }
    },
    "applied_changes": {
      "type": "array",
      "maxItems": 32,
      "description": "Canonical file/directory changes applied during initialization.",
      "x-data-class": "public",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "maxProperties": 4,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Repository-relative path.", "x-data-class": "public" },
          "action": { "type": "string", "enum": ["create_file", "create_directory", "update"], "description": "Applied initialization change action.", "x-data-class": "public" },
          "before_content_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Optional pre-init content digest.", "x-data-class": "public" },
          "after_content_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Optional post-init content digest.", "x-data-class": "public" }
        }
      }
    },
    "current_snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Snapshot observed at apply start.", "x-data-class": "public" },
    "resulting_snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Snapshot observed after apply attempt.", "x-data-class": "public" },
    "preview_token": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Preview token bound to this apply attempt.", "x-data-class": "public" },
    "approval_model": { "type": "string", "const": "shared_approval_and_hard_floor", "description": "Approval model for policy-gated or high-risk apply steps. Project-lifecycle apply reuses the shared approval and hard-floor model rather than introducing a setup-only approval lane.", "x-data-class": "public" }
  }
}
