{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/VersionInfoGetResponse.schema.json",
  "title": "VersionInfoGetResponse",
  "description": "Typed broker version/build info response.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "version_info"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.VersionInfoGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "version_info": { "$ref": "BrokerVersionInfo.schema.json", "description": "Broker version/build information model.", "x-data-class": "public" }
  }
}
