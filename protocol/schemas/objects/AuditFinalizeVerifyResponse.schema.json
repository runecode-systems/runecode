{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditFinalizeVerifyResponse.schema.json",
  "title": "AuditFinalizeVerifyResponse",
  "description": "Explicit broker-owned finalize/verify action result for the current sealed audit segment.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": ["schema_id", "schema_version", "request_id", "action_status"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.AuditFinalizeVerifyResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Echoed request identifier.", "x-data-class": "public" },
    "action_status": { "type": "string", "enum": ["ok", "failed"], "description": "Finalize/verify action status.", "x-data-class": "public" },
    "segment_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Segment verified by this action when status is ok.", "x-data-class": "public" },
    "report_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Digest identity for the persisted verification report when status is ok.", "x-data-class": "public" },
    "failure_code": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9._:-]+$", "description": "Stable machine-readable failure code.", "x-data-class": "public" },
    "failure_message": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Human-readable failure context.", "x-data-class": "public" }
  }
}
