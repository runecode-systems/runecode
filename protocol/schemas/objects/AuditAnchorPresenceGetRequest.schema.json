{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditAnchorPresenceGetRequest.schema.json",
  "title": "AuditAnchorPresenceGetRequest",
  "description": "Broker-owned local request to obtain anchor presence attestation material for one segment seal digest.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "seal_digest"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.AuditAnchorPresenceGetRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable caller-provided request identifier.", "x-data-class": "public" },
    "seal_digest": { "$ref": "AuditRecordDigest.schema.json#/$defs/auditRecordDigestValue", "description": "Digest identity of the target AuditSegmentSeal envelope.", "x-data-class": "public" }
  }
}
