{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GatewayScopeRule.schema.json",
  "title": "GatewayScopeRule",
  "description": "Typed gateway allowlist entry that binds destination identity to permitted operations, egress data classes, and redirect posture.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": [
    "schema_id",
    "schema_version",
    "scope_kind",
    "destination",
    "permitted_operations",
    "allowed_egress_data_classes",
    "redirect_posture"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GatewayScopeRule",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "scope_kind": {
      "type": "string",
      "enum": [
        "gateway_destination"
      ],
      "description": "Closed gateway scope-rule kind; unknown kinds fail closed.",
      "x-data-class": "public"
    },
    "gateway_role_kind": {
      "type": "string",
      "enum": [
        "model-gateway",
        "auth-gateway",
        "git-gateway",
        "web-research",
        "dependency-fetch"
      ],
      "description": "Optional concrete gateway role this scope rule is bound to.",
      "x-data-class": "public"
    },
    "destination": {
      "$ref": "DestinationDescriptor.schema.json",
      "description": "Canonical external destination identity.",
      "x-data-class": "public"
    },
    "permitted_operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "description": "Allowed gateway operations for this destination.",
      "x-data-class": "public",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "allowed_egress_data_classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "description": "Allowed outbound data classes for this destination and operation set.",
      "x-data-class": "public",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "redirect_posture": {
      "type": "string",
      "enum": [
        "deny",
        "allowlist_only"
      ],
      "description": "Redirect handling posture. Redirects may only target allowlisted destinations.",
      "x-data-class": "public"
    },
    "allow_credentials": {
      "type": "boolean",
      "description": "Optional explicit credential-forwarding control.",
      "x-data-class": "public"
    },
    "max_response_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647,
      "description": "Optional response-size bound for this rule.",
      "x-data-class": "public"
    }
  }
}
