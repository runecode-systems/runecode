{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadStageSummarySignOff.schema.json",
  "title": "ActionPayloadStageSummarySignOff",
  "description": "Typed action payload for stage summary sign-off operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 7,
  "required": [
    "schema_id",
    "schema_version",
    "run_id",
    "stage_id",
    "stage_summary_hash"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadStageSummarySignOff",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Bound run identifier.",
      "x-data-class": "sensitive"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Bound stage identifier.",
      "x-data-class": "sensitive"
    },
    "stage_summary_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Canonical stage summary hash.",
      "x-data-class": "public"
    },
    "approval_profile": {
      "type": "string",
      "enum": [
        "moderate"
      ],
      "description": "Approval profile in force for sign-off.",
      "x-data-class": "public"
    },
    "summary_revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic stage summary revision.",
      "x-data-class": "public"
    }
  }
}
