{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceSnapshotGetResponse.schema.json",
  "title": "AuditEvidenceSnapshotGetResponse",
  "description": "Typed response carrying broker-projected audit evidence preservation snapshot material.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "snapshot"],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceSnapshotGetResponse",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable echoed request identifier.",
      "x-data-class": "public"
    },
    "snapshot": {
      "$ref": "AuditEvidenceSnapshot.schema.json",
      "description": "Audit evidence snapshot preservation manifest.",
      "x-data-class": "public"
    }
  }
}
