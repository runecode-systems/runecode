{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadExecutorRun.schema.json",
  "title": "ActionPayloadExecutorRun",
  "description": "Typed action payload for executor run operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": [
    "schema_id",
    "schema_version",
    "executor_class",
    "executor_id",
    "argv"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadExecutorRun",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "executor_class": {
      "type": "string",
      "enum": [
        "workspace_ordinary",
        "system_modifying"
      ],
      "description": "Executor risk class for policy and approval semantics.",
      "x-data-class": "public"
    },
    "executor_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Deterministic executor identity.",
      "x-data-class": "public"
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "description": "Command-line arguments for execution.",
      "x-data-class": "sensitive",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "description": "One argv token."
      }
    },
    "working_directory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Workspace-relative working directory.",
      "x-data-class": "sensitive"
    },
    "network_access": {
      "type": "string",
      "enum": [
        "none",
        "gateway_only"
      ],
      "description": "Declared network posture for the executor run.",
      "x-data-class": "public"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400,
      "description": "Optional execution timeout.",
      "x-data-class": "public"
    }
  }
}
