{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderSetupSession.schema.json",
  "title": "ProviderSetupSession",
  "description": "Broker-owned provider setup session lifecycle metadata without raw secret material.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 14,
  "required": ["schema_id", "schema_version", "setup_session_id", "provider_profile_id", "provider_family", "supported_auth_modes", "current_phase", "current_auth_mode", "validation_status", "readiness_committed", "secret_ingress_ready", "created_at", "updated_at"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderSetupSession", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "setup_session_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Broker-owned setup session identifier.", "x-data-class": "public" },
    "provider_profile_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Provider profile bound to this setup session.", "x-data-class": "public" },
    "provider_family": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Provider family being configured.", "x-data-class": "public" },
    "supported_auth_modes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "description": "Auth modes supported by this provider profile setup lane.",
      "x-data-class": "public",
      "items": { "type": "string", "enum": ["direct_credential", "oauth_derived", "bridge_session"] }
    },
    "current_phase": { "type": "string", "enum": ["metadata_configured", "secret_ingress_ready", "credential_committed", "validation_in_progress", "readiness_committed"], "description": "Current setup/validation lifecycle phase.", "x-data-class": "public" },
    "current_auth_mode": { "type": "string", "enum": ["direct_credential", "oauth_derived", "bridge_session"], "description": "Auth mode selected for the profile.", "x-data-class": "public" },
    "validation_status": { "type": "string", "enum": ["not_started", "in_progress", "succeeded", "failed"], "description": "Validation lifecycle state for this setup session.", "x-data-class": "public" },
    "validation_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Latest broker-owned validation attempt identity for this session.", "x-data-class": "public" },
    "readiness_committed": { "type": "boolean", "description": "Whether broker-owned validation has committed a readiness decision.", "x-data-class": "public" },
    "secret_ingress_ready": { "type": "boolean", "description": "Whether a one-time secret ingress token is active.", "x-data-class": "public" },
    "created_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Session creation timestamp.", "x-data-class": "public" },
    "updated_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Session update timestamp.", "x-data-class": "public" }
  }
}
