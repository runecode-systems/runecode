{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitRemoteMutationExecuteResponse.schema.json",
  "title": "GitRemoteMutationExecuteResponse",
  "description": "Execute response for prepared git remote mutation control-plane execution handoff.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "prepared_mutation_id",
    "execution_state",
    "prepared"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GitRemoteMutationExecuteResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier echoed from request.",
      "x-data-class": "public"
    },
    "prepared_mutation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Prepared mutation identifier executed.",
      "x-data-class": "public"
    },
    "execution_state": {
      "type": "string",
      "enum": ["deferred", "blocked", "failed", "completed"],
      "description": "Execution posture result after execute handling.",
      "x-data-class": "public"
    },
    "prepared": { "$ref": "GitRemoteMutationPreparedState.schema.json", "description": "Updated durable prepared mutation state record.", "x-data-class": "public" }
  }
}
