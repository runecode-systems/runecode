{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceRetentionReviewRequest.schema.json",
  "title": "AuditEvidenceRetentionReviewRequest",
  "description": "Trusted local request for retention/backfill completeness review using preservation snapshots against canonical bundle manifests.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "scope"],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceRetentionReviewRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request identifier.",
      "x-data-class": "public"
    },
    "scope": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/scope",
      "description": "Scope used to review snapshot-vs-bundle completeness.",
      "x-data-class": "public"
    }
  }
}
