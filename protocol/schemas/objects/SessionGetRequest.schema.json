{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionGetRequest.schema.json",
  "title": "SessionGetRequest",
  "description": "Typed session detail request by canonical session identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "session_id"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionGetRequest", "description": "Protocol schema identifier for SessionGetRequest.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for SessionGetRequest.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable caller request identity.", "x-data-class": "public" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Canonical session identity to read.", "x-data-class": "public" }
  }
}
