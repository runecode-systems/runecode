{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderSetupSecretIngressPrepareRequest.schema.json",
  "title": "ProviderSetupSecretIngressPrepareRequest",
  "description": "Typed request to mint one-time secret ingress token for a setup session.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "setup_session_id", "ingress_channel", "credential_field"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderSetupSecretIngressPrepareRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "setup_session_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Setup session identifier.", "x-data-class": "public" },
    "ingress_channel": { "type": "string", "enum": ["cli_stdin", "tui_masked_input"], "description": "Trusted secret ingress channel kind.", "x-data-class": "public" },
    "credential_field": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Credential field being entered.", "x-data-class": "public" }
  }
}
