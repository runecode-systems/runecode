  "$defs": {
    "egressDataClass": {
      "type": "string",
      "description": "Closed egress data-class vocabulary used by gateway policy and allowlist matching.",
      "enum": [
        "spec_text",
        "unapproved_file_excerpts",
        "approved_file_excerpts",
        "diffs",
        "build_logs",
        "audit_events",
        "audit_verification_report",
        "audit_receipt_export_copy",
        "gate_evidence",
        "web_query",
        "web_citations"
      ]
    },
    "gatewayOperation": {
      "type": "string",
      "description": "Closed shared gateway operation vocabulary spanning request execution, scope change, and remote-state mutation semantics.",
      "enum": [
        "invoke_model",
        "fetch_dependency",
        "exchange_auth_code",
        "refresh_auth_token",
        "git_ref_update",
        "git_pull_request_create",
        "enable_gateway",
        "expand_scope",
        "change_allowlist",
        "enable_dependency_fetch"
      ]
