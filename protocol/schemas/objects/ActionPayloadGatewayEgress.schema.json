          "maximum": 2147483647,
          "description": "Observed outbound bytes for the destination-bound exchange.",
          "x-data-class": "public"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64,
          "description": "RFC 3339 start timestamp for destination-bound exchange timing.",
          "x-data-class": "public"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64,
          "description": "RFC 3339 completion timestamp for destination-bound exchange timing.",
          "x-data-class": "public"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "admission_denied",
            "admission_allowed",
            "streaming_in_progress",
            "streaming_truncated",
            "succeeded",
            "failed",
            "timeout"
          ],
          "description": "Typed outbound outcome posture used for audit and fail-closed reconciliation.",
          "x-data-class": "public"
        },
        "request_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical LLMRequest hash when the outbound exchange is request-bound.",
          "x-data-class": "public"
        },
        "response_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical LLMResponse hash when a final response object exists.",
          "x-data-class": "public"
        },
        "lease_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Canonical lease identity used for this exchange when leased auth material is bound.",
          "x-data-class": "public"
        },
        "policy_decision_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
