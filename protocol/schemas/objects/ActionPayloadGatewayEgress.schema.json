  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadGatewayEgress",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "gateway_role_kind": {
      "type": "string",
      "enum": [
        "model-gateway",
        "auth-gateway",
        "git-gateway",
        "web-research",
        "dependency-fetch"
      ],
      "description": "Concrete gateway role used for egress.",
      "x-data-class": "public"
    },
    "destination_kind": {
      "type": "string",
