{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadGatewayEgress.schema.json",
  "title": "ActionPayloadGatewayEgress",
  "description": "Typed action payload for gateway egress operations with a closed shared gateway operation vocabulary spanning request execution, scope change, and remote-state mutation semantics.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 13,
  "required": [
    "schema_id",
    "schema_version",
    "gateway_role_kind",
    "destination_kind",
    "destination_ref",
    "egress_data_class",
