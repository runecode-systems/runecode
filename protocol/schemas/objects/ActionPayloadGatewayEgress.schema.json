        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "description": "Scope-change operations must not bind a request payload hash.",
        "properties": {
          "payload_hash": {
            "not": {}
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "invoke_model",
              "fetch_dependency",
              "exchange_auth_code",
              "refresh_auth_token"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "description": "Request-execution operations require both audit and quota context.",
        "required": [
          "audit_context",
          "quota_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "invoke_model",
              "fetch_dependency",
              "exchange_auth_code",
              "refresh_auth_token",
              "enable_gateway",
              "expand_scope",
              "change_allowlist",
              "enable_dependency_fetch"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "description": "Non-git operations must not carry git-specific request or runtime proof payloads.",
        "properties": {
