      "x-data-class": "public"
    },
    "quota_context": {
      "$ref": "#/$defs/gatewayQuotaContext",
      "description": "Optional trusted quota context used for admission-time and streaming enforcement decisions.",
      "x-data-class": "public"
    },
    "git_request": {
      "$ref": "#/$defs/gitTypedRequestUnion",
      "description": "Authoritative provider-neutral typed git request object used for exact approval and runtime binding.",
      "x-data-class": "public"
    },
    "git_runtime_proof": {
      "$ref": "#/$defs/gitRuntimeProof",
      "description": "Runtime outbound verification proof for git remote mutation, including drift checks and observed result bindings.",
      "x-data-class": "public"
