{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadGatewayEgress.schema.json",
  "title": "ActionPayloadGatewayEgress",
  "description": "Typed action payload for gateway egress operations with a closed shared gateway operation vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 11,
  "required": [
    "schema_id",
    "schema_version",
    "gateway_role_kind",
    "destination_kind",
    "destination_ref",
    "egress_data_class",
    "operation"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadGatewayEgress",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "gateway_role_kind": {
      "type": "string",
      "enum": [
        "model-gateway",
        "auth-gateway",
        "git-gateway",
        "web-research",
        "dependency-fetch"
      ],
      "description": "Concrete gateway role used for egress.",
      "x-data-class": "public"
    },
    "destination_kind": {
      "type": "string",
      "enum": [
        "model_endpoint",
        "auth_provider",
        "git_remote",
        "web_origin",
        "package_registry"
      ],
      "description": "Typed destination descriptor family.",
      "x-data-class": "public"
    },
    "destination_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9.-]+(?::(?:6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3}))?(?:/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*)?$",
      "description": "Canonical allowlist destination reference in host[:port][/path] form (no scheme, credentials, query, or fragment).",
      "x-data-class": "sensitive"
    },
    "egress_data_class": {
      "$ref": "#/$defs/egressDataClass",
      "description": "Data class being sent through the gateway.",
      "x-data-class": "public"
    },
    "operation": {
      "$ref": "#/$defs/gatewayOperation",
      "description": "Gateway operation requested.",
      "x-data-class": "public"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300,
      "description": "Optional per-request gateway timeout bound in seconds.",
      "x-data-class": "public"
    },
    "payload_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Optional digest of egress payload.",
      "x-data-class": "public"
    },
    "audit_context": {
      "$ref": "#/$defs/gatewayAuditContext",
      "description": "Optional outbound audit context carrying byte, timing, outcome, and identity bindings.",
      "x-data-class": "public"
    },
    "quota_context": {
      "$ref": "#/$defs/gatewayQuotaContext",
      "description": "Optional trusted quota context used for admission-time and streaming enforcement decisions.",
      "x-data-class": "public"
    }
  },
  "$defs": {
    "egressDataClass": {
      "type": "string",
      "description": "Closed egress data-class vocabulary used by gateway policy and allowlist matching.",
      "enum": [
        "spec_text",
        "unapproved_file_excerpts",
        "approved_file_excerpts",
        "diffs",
        "build_logs",
        "audit_events",
        "audit_verification_report",
        "audit_receipt_export_copy",
        "gate_evidence",
        "web_query",
        "web_citations"
      ]
    },
    "gatewayOperation": {
      "type": "string",
      "description": "Closed shared gateway operation vocabulary.",
      "enum": [
        "invoke_model",
        "fetch_dependency",
        "exchange_auth_code",
        "refresh_auth_token",
        "enable_gateway",
        "expand_scope",
        "change_allowlist",
        "enable_dependency_fetch"
      ]
    },
    "gatewayAuditContext": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 10,
      "required": [
        "schema_id",
        "schema_version",
        "outbound_bytes",
        "started_at",
        "completed_at",
        "outcome"
      ],
      "properties": {
        "schema_id": {
          "const": "runecode.protocol.v0.GatewayAuditContext",
          "description": "Protocol schema identifier.",
          "x-data-class": "public"
        },
        "schema_version": {
          "const": "0.1.0",
          "description": "Protocol schema version.",
          "x-data-class": "public"
        },
        "outbound_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Observed outbound bytes for the destination-bound exchange.",
          "x-data-class": "public"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64,
          "description": "RFC 3339 start timestamp for destination-bound exchange timing.",
          "x-data-class": "public"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64,
          "description": "RFC 3339 completion timestamp for destination-bound exchange timing.",
          "x-data-class": "public"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "admission_denied",
            "admission_allowed",
            "streaming_in_progress",
            "streaming_truncated",
            "succeeded",
            "failed",
            "timeout"
          ],
          "description": "Typed outbound outcome posture used for audit and fail-closed reconciliation.",
          "x-data-class": "public"
        },
        "request_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical LLMRequest hash when the outbound exchange is request-bound.",
          "x-data-class": "public"
        },
        "response_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical LLMResponse hash when a final response object exists.",
          "x-data-class": "public"
        },
        "lease_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Canonical lease identity used for this exchange when leased auth material is bound.",
          "x-data-class": "public"
        },
        "policy_decision_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical policy decision hash that admitted or denied this outbound exchange.",
          "x-data-class": "public"
        }
      },
      "description": "Outbound audit context binding destination bytes/timing/outcome and request/response/lease/policy identities."
    },
    "gatewayQuotaMeters": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 7,
      "properties": {
        "request_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Request-unit meter used by request-count quota products.",
          "x-data-class": "public"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Input-token meter used by token-priced APIs.",
          "x-data-class": "public"
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Output-token meter used by token-priced APIs.",
          "x-data-class": "public"
        },
        "streamed_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Streamed-byte meter used for streaming quotas.",
          "x-data-class": "public"
        },
        "concurrency_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Concurrency-unit meter used for parallel request ceilings.",
          "x-data-class": "public"
        },
        "spend_micros": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9223372036854775807,
          "description": "Spend meter in micros for monetary budget ceilings.",
          "x-data-class": "public"
        },
        "entitlement_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "description": "Entitlement-unit meter used for request-entitlement products (for example premium requests).",
          "x-data-class": "public"
        }
      },
      "anyOf": [
        {
          "required": [
            "request_units"
          ]
        },
        {
          "required": [
            "input_tokens"
          ]
        },
        {
          "required": [
            "output_tokens"
          ]
        },
        {
          "required": [
            "streamed_bytes"
          ]
        },
        {
          "required": [
            "concurrency_units"
          ]
        },
        {
          "required": [
            "spend_micros"
          ]
        },
        {
          "required": [
            "entitlement_units"
          ]
        }
      ],
      "description": "Meter values for one trusted quota abstraction covering token-metered and request-entitlement products."
    },
    "gatewayQuotaContext": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 7,
      "required": [
        "schema_id",
        "schema_version",
        "quota_profile_kind",
        "phase",
        "enforce_during_stream",
        "meters"
      ],
      "properties": {
        "schema_id": {
          "const": "runecode.protocol.v0.GatewayQuotaContext",
          "description": "Protocol schema identifier.",
          "x-data-class": "public"
        },
        "schema_version": {
          "const": "0.1.0",
          "description": "Protocol schema version.",
          "x-data-class": "public"
        },
        "quota_profile_kind": {
          "type": "string",
          "enum": [
            "token_metered_api",
            "request_entitlement",
            "hybrid"
          ],
          "description": "Trusted quota profile family that can represent token-metered APIs and request-entitlement products.",
          "x-data-class": "public"
        },
        "phase": {
          "type": "string",
          "enum": [
            "admission",
            "stream"
          ],
          "description": "Quota handling phase; admission is preflight and stream is mid-stream enforcement.",
          "x-data-class": "public"
        },
        "enforce_during_stream": {
          "type": "boolean",
          "description": "Whether streaming limits must be enforced continuously after admission.",
          "x-data-class": "public"
        },
        "stream_limit_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647,
          "description": "Optional explicit stream byte cap when streaming enforcement is enabled.",
          "x-data-class": "public"
        },
        "meters": {
          "$ref": "#/$defs/gatewayQuotaMeters",
          "description": "Meter values consumed by the trusted quota abstraction.",
          "x-data-class": "public"
        }
      },
      "description": "Trusted quota context for admission-time and streaming-phase quota enforcement."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "invoke_model",
              "fetch_dependency",
              "exchange_auth_code",
              "refresh_auth_token"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "required": [
          "payload_hash"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "enable_gateway",
              "expand_scope",
              "change_allowlist",
              "enable_dependency_fetch"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "payload_hash": {
            "not": {}
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "invoke_model",
              "fetch_dependency",
              "exchange_auth_code",
              "refresh_auth_token"
            ]
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "required": [
          "audit_context",
          "quota_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "quota_context": {
            "properties": {
              "quota_profile_kind": {
                "const": "hybrid"
              }
            },
            "required": [
              "quota_profile_kind"
            ]
          }
        },
        "required": [
          "quota_context"
        ]
      },
      "then": {
        "properties": {
          "quota_context": {
            "properties": {
              "meters": {
                "allOf": [
                  {
                    "anyOf": [
                      {
                        "required": [
                          "input_tokens"
                        ]
                      },
                      {
                        "required": [
                          "output_tokens"
                        ]
                      }
                    ]
                  },
                  {
                    "anyOf": [
                      {
                        "required": [
                          "request_units"
                        ]
                      },
                      {
                        "required": [
                          "entitlement_units"
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            "required": [
              "meters"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "quota_context": {
            "properties": {
              "phase": {
                "const": "stream"
              }
            },
            "required": [
              "phase"
            ]
          }
        },
        "required": [
          "quota_context"
        ]
      },
      "then": {
        "properties": {
          "quota_context": {
            "properties": {
              "enforce_during_stream": {
                "const": true
              },
              "stream_limit_bytes": {
                "type": "integer",
                "minimum": 1
              }
            },
            "required": [
              "enforce_during_stream",
              "stream_limit_bytes"
            ]
          }
        }
      }
    }
  ]
}
