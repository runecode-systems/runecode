          "operation"
        ]
      },
      "then": {
        "description": "Remote-state-mutation operations require payload, audit, and git binding proof on the shared gateway path.",
        "required": [
          "payload_hash",
          "audit_context",
          "git_request",
          "git_runtime_proof"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "enable_gateway",
              "expand_scope",
              "change_allowlist",
              "enable_dependency_fetch"
