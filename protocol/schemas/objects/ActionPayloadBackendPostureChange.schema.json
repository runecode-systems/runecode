{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadBackendPostureChange.schema.json",
  "title": "ActionPayloadBackendPostureChange",
  "description": "Typed action payload for backend posture change operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 9,
  "required": [
    "schema_id",
    "schema_version",
    "target_backend_kind",
    "selection_mode",
    "change_kind",
    "assurance_change_kind",
    "opt_in_kind",
    "reduced_assurance_acknowledged"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadBackendPostureChange",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "target_backend_kind": {
      "type": "string",
      "enum": [
        "microvm",
        "container"
      ],
      "description": "Typed target backend selection.",
      "x-data-class": "public"
    },
    "selection_mode": {
      "type": "string",
      "enum": [
        "explicit_selection",
        "automatic_fallback_attempt"
      ],
      "description": "Typed selection posture for explicit selection vs fallback attempt semantics.",
      "x-data-class": "public"
    },
    "change_kind": {
      "type": "string",
      "enum": [
        "select_backend",
        "relax_isolation"
      ],
      "description": "Backend posture change kind.",
      "x-data-class": "public"
    },
    "assurance_change_kind": {
      "type": "string",
      "enum": [
        "reduce_assurance",
        "maintain_assurance",
        "increase_assurance"
      ],
      "description": "Typed assurance delta classification for backend posture transitions.",
      "x-data-class": "public"
    },
    "opt_in_kind": {
      "type": "string",
      "enum": [
        "exact_action_approval",
        "none"
      ],
      "description": "Typed opt-in semantics; trust root remains exact-action approval binding.",
      "x-data-class": "public"
    },
    "reduced_assurance_acknowledged": {
      "type": "boolean",
      "description": "Explicit user acknowledgment that container mode reduces runtime isolation assurance.",
      "x-data-class": "public"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Human-readable reason for posture change.",
      "x-data-class": "sensitive"
    }
  }
}
