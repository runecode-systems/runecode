{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ExternalAnchorMutationIssueExecuteLeaseRequest.schema.json",
  "title": "ExternalAnchorMutationIssueExecuteLeaseRequest",
  "description": "Request a broker-issued execute lease bound to a prepared external anchor mutation.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "prepared_mutation_id"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ExternalAnchorMutationIssueExecuteLeaseRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier.",
      "x-data-class": "public"
    },
    "prepared_mutation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Prepared mutation identifier to bind the execute lease to.",
      "x-data-class": "public"
    },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600,
      "description": "Optional requested lease TTL; broker applies defaults and hard caps fail closed.",
      "x-data-class": "public"
    }
  }
}
