{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderCredentialLeaseIssueResponse.schema.json",
  "title": "ProviderCredentialLeaseIssueResponse",
  "description": "Typed response containing model-gateway-scoped provider credential lease metadata.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "provider_profile_id", "provider_auth_lease_id", "lease"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderCredentialLeaseIssueResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "provider_profile_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Provider profile whose credential lease was issued.", "x-data-class": "public" },
    "provider_auth_lease_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Canonical issued provider credential lease identity.", "x-data-class": "public" },
    "lease": {
      "type": "object",
      "description": "Issued scope-bound lease metadata.",
      "additionalProperties": false,
      "maxProperties": 9,
      "required": ["lease_id", "secret_ref", "consumer_id", "role_kind", "scope", "delivery_kind", "status"],
      "properties": {
        "lease_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Lease identifier.", "x-data-class": "public" },
        "secret_ref": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Secret reference bound to the lease.", "x-data-class": "public" },
        "consumer_id": { "type": "string", "minLength": 1, "maxLength": 256, "description": "Consumer principal binding.", "x-data-class": "public" },
        "role_kind": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Role kind binding for the lease consumer.", "x-data-class": "public" },
        "scope": { "type": "string", "minLength": 1, "maxLength": 256, "description": "Scope binding for the lease consumer.", "x-data-class": "public" },
        "delivery_kind": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Delivery kind bound to lease retrieval.", "x-data-class": "public" },
        "status": { "type": "string", "minLength": 1, "maxLength": 32, "description": "Lease lifecycle status.", "x-data-class": "public" },
        "issued_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Lease issuance timestamp.", "x-data-class": "public" },
        "expires_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Lease expiration timestamp.", "x-data-class": "public" }
      },
      "x-data-class": "public"
    }
  }
}
