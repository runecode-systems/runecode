{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateAdoptResponse.schema.json",
  "title": "ProjectSubstrateAdoptResponse",
  "description": "Typed response for read-only adoption of existing canonical project substrate.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "adoption"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateAdoptResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "adoption": { "$ref": "ProjectSubstrateAdoptionResult.schema.json", "description": "Read-only adoption result.", "x-data-class": "public" }
  }
}
