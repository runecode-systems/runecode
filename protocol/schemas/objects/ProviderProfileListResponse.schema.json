{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderProfileListResponse.schema.json",
  "title": "ProviderProfileListResponse",
  "description": "Typed response listing broker-projected provider profile setup, readiness, and compatibility posture.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "profiles"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderProfileListResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request correlation identifier.", "x-data-class": "public" },
    "profiles": {
      "type": "array",
      "maxItems": 256,
      "description": "Broker-projected provider profiles with setup/auth/readiness/compatibility posture.",
      "items": { "$ref": "ProviderProfile.schema.json" },
      "x-data-class": "public"
    }
  }
}
