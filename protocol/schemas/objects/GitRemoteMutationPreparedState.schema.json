{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitRemoteMutationPreparedState.schema.json",
  "title": "GitRemoteMutationPreparedState",
  "description": "Authoritative prepared-mutation record state for broker-local git remote mutation control-plane.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 31,
  "required": [
    "schema_id",
    "schema_version",
    "prepared_mutation_id",
    "run_id",
    "provider",
    "destination_ref",
    "request_kind",
    "typed_request_schema_id",
    "typed_request_schema_version",
    "typed_request",
    "typed_request_hash",
    "action_request_hash",
    "policy_decision_hash",
    "lifecycle_state",
    "execution_state",
    "created_at",
    "updated_at",
    "derived_summary"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GitRemoteMutationPreparedState", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "prepared_mutation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable prepared mutation identifier.",
      "x-data-class": "public"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Run identifier bound to this prepared mutation.",
      "x-data-class": "public"
    },
    "provider": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Git provider selected for execution.", "x-data-class": "public" },
    "destination_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9.-]+(?::(?:6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3}))?(?:/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*)?$",
      "description": "Canonical destination reference bound at prepare time.",
      "x-data-class": "sensitive"
    },
    "request_kind": { "type": "string", "enum": ["git_ref_update", "git_pull_request_create"], "description": "Typed git request kind.", "x-data-class": "public" },
    "typed_request_schema_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Schema identifier of the authoritative typed request object.",
      "x-data-class": "public"
    },
    "typed_request_schema_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "description": "Schema version of the authoritative typed request object.",
      "x-data-class": "public"
    },
    "typed_request": {
      "oneOf": [
        { "$ref": "GitRefUpdateRequest.schema.json" },
        { "$ref": "GitPullRequestCreateRequest.schema.json" }
      ],
      "description": "Authoritative provider-neutral typed request object.",
      "x-data-class": "public"
    },
    "typed_request_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical hash of the authoritative typed request object.", "x-data-class": "public" },
    "action_request_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical action request hash bound during prepare policy evaluation.", "x-data-class": "public" },
    "policy_decision_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical policy decision hash bound during prepare policy evaluation.", "x-data-class": "public" },
    "required_approval_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "maxLength": 71,
      "description": "Required approval identifier resolved at prepare time.",
      "x-data-class": "public"
    },
    "required_approval_request_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Bound approval request digest required at execute time.", "x-data-class": "public" },
    "required_approval_decision_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Bound approval decision digest required at execute time.", "x-data-class": "public" },
    "lifecycle_state": {
      "type": "string",
      "enum": ["prepared", "executing", "executed", "failed"],
      "description": "Prepared mutation lifecycle state.",
      "x-data-class": "public"
    },
    "lifecycle_reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9_]+$",
      "description": "Lifecycle reason code when applicable.",
      "x-data-class": "public"
    },
    "execution_state": {
      "type": "string",
      "enum": ["not_started", "deferred", "blocked", "failed", "completed"],
      "description": "Execution posture state for the prepared mutation.",
      "x-data-class": "public"
    },
    "execution_reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9_]+$",
      "description": "Execution reason code when applicable.",
      "x-data-class": "public"
    },
    "created_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Creation timestamp for the durable prepared record.", "x-data-class": "public" },
    "updated_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Last update timestamp for the durable prepared record.", "x-data-class": "public" },
    "derived_summary": { "$ref": "GitRemoteMutationDerivedSummary.schema.json", "description": "Derived non-authoritative summary projection for display.", "x-data-class": "public" },
    "last_prepare_request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Last prepare request identifier recorded for diagnostics.", "x-data-class": "public" },
    "last_get_request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Last get request identifier recorded for diagnostics.", "x-data-class": "public" },
    "last_execute_request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Last execute request identifier recorded for diagnostics.", "x-data-class": "public" },
    "last_execute_provider_auth_lease_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Last execute provider auth lease identifier recorded for diagnostics and execution binding traceability.",
      "x-data-class": "public"
    },
    "last_execute_attempt_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "maxLength": 71,
      "description": "Durable execute attempt id bound to immutable request inputs.",
      "x-data-class": "public"
    },
    "last_execute_attempt_typed_request_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Execute attempt immutable binding to authoritative typed request hash.",
      "x-data-class": "public"
    },
    "last_execute_snapshot_segment_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Immutable segment identifier snapshot captured before outbound execution.",
      "x-data-class": "public"
    },
    "last_execute_snapshot_seal_digest": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Immutable seal digest snapshot captured before outbound execution when available.",
      "x-data-class": "public"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["last_execute_request_id"],
        "properties": {
          "lifecycle_state": {
            "not": { "const": "executed" }
          }
        }
      },
      "then": {
        "required": [
          "last_execute_provider_auth_lease_id",
          "last_execute_attempt_id",
          "last_execute_attempt_typed_request_hash"
        ]
      }
    },
    {
      "if": {
        "required": ["last_execute_request_id"],
        "properties": {
          "lifecycle_state": { "const": "executed" },
          "execution_state": {
            "not": { "const": "completed" }
          }
        }
      },
      "then": {
        "required": [
          "last_execute_provider_auth_lease_id",
          "last_execute_attempt_id",
          "last_execute_attempt_typed_request_hash"
        ]
      }
    },
    {
      "if": {
        "anyOf": [
          { "required": ["last_execute_provider_auth_lease_id"] },
          { "required": ["last_execute_attempt_id"] },
          { "required": ["last_execute_attempt_typed_request_hash"] }
        ]
      },
      "then": {
        "required": [
          "last_execute_provider_auth_lease_id",
          "last_execute_attempt_id",
          "last_execute_attempt_typed_request_hash"
        ]
      }
    }
  ]
}
