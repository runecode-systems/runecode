{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitSetupAuthBootstrapRequest.schema.json",
  "title": "GitSetupAuthBootstrapRequest",
  "description": "Typed request for broker-owned git provider auth bootstrap.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": ["schema_id", "schema_version", "request_id", "provider", "mode"],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GitSetupAuthBootstrapRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier.",
      "x-data-class": "public"
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Git provider whose auth bootstrap flow should be started.",
      "x-data-class": "public"
    },
    "mode": {
      "type": "string",
      "enum": ["browser", "device_code", "interactive_token_prompt"],
      "description": "Requested broker-owned bootstrap mode.",
      "x-data-class": "public"
    }
  }
}
