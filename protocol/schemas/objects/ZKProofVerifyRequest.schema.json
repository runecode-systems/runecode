{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ZKProofVerifyRequest.schema.json",
  "title": "ZKProofVerifyRequest",
  "description": "Explicit trusted request to verify one persisted ZK proof artifact by immutable proof identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "zk_proof_artifact_digest"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ZKProofVerifyRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request identifier.", "x-data-class": "public" },
    "zk_proof_artifact_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Digest identity of persisted ZK proof artifact to verify.", "x-data-class": "public" }
  }
}
