{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/RunSummary.schema.json",
  "title": "RunSummary",
  "description": "Stable list-facing run read model for broker local API responses.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 25,
  "required": ["schema_id", "schema_version", "run_id", "workspace_id", "created_at", "updated_at", "lifecycle_state", "pending_approval_count", "approval_profile", "backend_kind", "isolation_assurance_level", "provisioning_posture", "assurance_level", "audit_integrity_status", "audit_anchoring_status", "audit_currently_degraded", "runtime_posture_degraded"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.RunSummary", "description": "Protocol schema identifier for RunSummary.", "x-data-class": "public" },
    "schema_version": { "const": "0.2.0", "description": "Protocol schema version for RunSummary.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable run identifier.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Workspace identifier bound to the run.", "x-data-class": "public" },
    "project_context_identity_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Validated project-context identity digest bound to canonical project-substrate snapshot identity.", "x-data-class": "public" },
    "workflow_kind": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Workflow kind identifier.", "x-data-class": "public" },
    "workflow_definition_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Workflow definition digest identity.", "x-data-class": "public" },
    "created_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Run creation time.", "x-data-class": "public" },
    "started_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Run start time.", "x-data-class": "public" },
    "updated_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Run update time.", "x-data-class": "public" },
    "finished_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Run finish time for terminal runs.", "x-data-class": "public" },
    "lifecycle_state": { "type": "string", "enum": ["pending", "starting", "active", "blocked", "recovering", "completed", "failed", "cancelled"], "description": "Normalized run lifecycle state.", "x-data-class": "public" },
    "current_stage_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Current stage identifier.", "x-data-class": "public" },
    "pending_approval_count": { "type": "integer", "minimum": 0, "description": "Current pending approvals bound to this run.", "x-data-class": "public" },
    "approval_profile": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Approval profile active for this run.", "x-data-class": "public" },
    "backend_kind": { "type": "string", "enum": ["microvm", "container", "unknown"], "description": "Execution backend kind in closed operator-visible vocabulary.", "x-data-class": "public" },
    "isolation_assurance_level": { "type": "string", "enum": ["isolated", "degraded", "unknown"], "description": "Canonical runtime isolation assurance posture.", "x-data-class": "public" },
    "provisioning_posture": { "type": "string", "enum": ["tofu", "attested", "not_applicable", "unknown"], "description": "Provisioning/binding posture kept distinct from runtime isolation assurance; supports not_applicable where backend mechanics differ.", "x-data-class": "public" },
    "assurance_level": { "type": "string", "enum": ["isolated", "degraded", "unknown"], "description": "Migration-compatible alias for isolation_assurance_level.", "x-data-class": "public" },
    "blocking_reason_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Optional blocking reason code.", "x-data-class": "public" },
    "audit_integrity_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Audit integrity posture summary.", "x-data-class": "public" },
    "audit_anchoring_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Audit anchoring posture summary.", "x-data-class": "public" },
    "audit_currently_degraded": { "type": "boolean", "description": "Whether audit posture is currently degraded.", "x-data-class": "public" },
    "runtime_posture_degraded": { "type": "boolean", "description": "Whether runtime-isolation posture is currently degraded (for example, container reduced-assurance mode).", "x-data-class": "public" }
  }
}
