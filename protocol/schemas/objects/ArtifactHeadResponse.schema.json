{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ArtifactHeadResponse.schema.json",
  "title": "ArtifactHeadResponse",
  "description": "Typed artifact metadata response.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "artifact"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ArtifactHeadResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "artifact": { "$ref": "ArtifactSummary.schema.json", "description": "Artifact metadata summary.", "x-data-class": "public" }
  }
}
