{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderSetupSecretIngressPrepareResponse.schema.json",
  "title": "ProviderSetupSecretIngressPrepareResponse",
  "description": "Typed response carrying one-time secret ingress token metadata.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "setup_session", "secret_ingress_token", "expires_at"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderSetupSecretIngressPrepareResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "setup_session": { "$ref": "ProviderSetupSession.schema.json", "description": "Updated setup session state.", "x-data-class": "public" },
    "secret_ingress_token": { "type": "string", "minLength": 1, "maxLength": 128, "description": "One-time token authorizing secret ingress submit.", "x-data-class": "public" },
    "expires_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Token expiration timestamp.", "x-data-class": "public" }
  }
}
