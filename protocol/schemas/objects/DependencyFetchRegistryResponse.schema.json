{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/DependencyFetchRegistryResponse.schema.json",
  "title": "DependencyFetchRegistryResponse",
  "description": "Broker-owned response for canonical single dependency fetch/cache ensure.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "request_id", "request_hash", "resolved_unit_digest", "manifest_digest", "payload_digests", "cache_outcome", "fetched_bytes", "registry_request_count"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.DependencyFetchRegistryResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request correlation identifier.", "x-data-class": "public" },
    "request_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical dependency request digest identity.", "x-data-class": "public" },
    "resolved_unit_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical resolved-unit digest.", "x-data-class": "public" },
    "manifest_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Dependency resolved-unit manifest artifact digest.", "x-data-class": "public" },
    "payload_digests": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "$ref": "Digest.schema.json#/$defs/digestValue" }, "description": "Dependency payload artifact digests.", "x-data-class": "public" },
    "cache_outcome": { "type": "string", "enum": ["hit_exact", "miss_filled"], "description": "Authoritative cache result classification.", "x-data-class": "public" },
    "fetched_bytes": { "type": "integer", "minimum": 0, "maximum": 1099511627776, "description": "Bytes fetched from registry for this request.", "x-data-class": "public" },
    "registry_request_count": { "type": "integer", "minimum": 0, "maximum": 1, "description": "Registry requests executed for this request after miss coalescing.", "x-data-class": "public" }
  }
}
