{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalListResponse.schema.json",
  "title": "ApprovalListResponse",
  "description": "Typed approval list response with ordering semantics and continuation cursor.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "order", "approvals"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalListResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "order": { "type": "string", "enum": ["pending_first_newest_within_status"], "description": "Ordering applied to approvals page.", "x-data-class": "public" },
    "approvals": { "type": "array", "maxItems": 200, "description": "Approval summary entries.", "x-data-class": "public", "items": { "$ref": "ApprovalSummary.schema.json", "description": "Approval summary entry.", "x-data-class": "public" } },
    "next_cursor": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Opaque continuation cursor.", "x-data-class": "public" }
  }
}
