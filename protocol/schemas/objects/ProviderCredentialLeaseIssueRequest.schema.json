{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderCredentialLeaseIssueRequest.schema.json",
  "title": "ProviderCredentialLeaseIssueRequest",
  "description": "Typed request for model-gateway-scoped provider credential lease issuance.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "provider_profile_id", "run_id"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderCredentialLeaseIssueRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "provider_profile_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Provider profile whose credentials should be leased.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Run scope for model-gateway lease binding.", "x-data-class": "public" },
    "ttl_seconds": { "type": "integer", "minimum": 0, "maximum": 3600, "description": "Requested lease TTL seconds.", "x-data-class": "public" }
  }
}
