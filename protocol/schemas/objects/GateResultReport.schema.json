{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GateResultReport.schema.json",
  "title": "GateResultReport",
  "description": "Typed advisory gate terminal result report from untrusted runner to broker.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 23,
  "required": [
    "schema_id",
    "schema_version",
    "gate_id",
    "gate_kind",
    "gate_version",
    "gate_attempt_id",
    "lifecycle_state",
    "result_code",
    "occurred_at",
    "idempotency_key"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GateResultReport", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "gate_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Stable gate identity.", "x-data-class": "public" },
    "gate_kind": { "type": "string", "enum": ["build", "test", "lint", "format", "secret_scan", "policy"], "description": "Gate taxonomy kind.", "x-data-class": "public" },
    "gate_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$", "maxLength": 32, "description": "Gate contract version.", "x-data-class": "public" },
    "gate_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Gate attempt identity for retry/rerun tracking.", "x-data-class": "public" },
    "lifecycle_state": { "type": "string", "enum": ["passed", "failed", "overridden", "superseded"], "description": "Gate terminal lifecycle state vocabulary.", "x-data-class": "public" },
    "result_code": { "type": "string", "enum": ["gate_passed", "gate_failed", "gate_overridden", "gate_superseded"], "description": "Stable gate terminal result code.", "x-data-class": "public" },
    "occurred_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Terminal event time.", "x-data-class": "public" },
    "idempotency_key": { "type": "string", "minLength": 1, "maxLength": 256, "description": "Stable idempotency key for replay safety.", "x-data-class": "public" },
    "plan_checkpoint_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Plan-derived checkpoint placement identity from trusted run plan compilation.", "x-data-class": "public" },
    "plan_order_index": { "type": "integer", "minimum": 0, "description": "Plan-derived deterministic gate placement order index from trusted run plan compilation.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Run identity when provided in report payload.", "x-data-class": "public" },
    "stage_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable stage identity when known.", "x-data-class": "public" },
    "step_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable step identity when known.", "x-data-class": "public" },
    "role_instance_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable role-instance identity when known.", "x-data-class": "public" },
    "stage_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stage attempt identity for retry/recovery tracking.", "x-data-class": "public" },
    "step_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Step attempt identity for retry/recovery tracking.", "x-data-class": "public" },
    "failure_reason_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Optional normalized failure reason code for failed result.", "x-data-class": "public" },
    "overridden_failed_result_ref": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Failed gate result identity referenced by override path when lifecycle_state=overridden.", "x-data-class": "public" },
    "gate_evidence_ref": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Canonical gate evidence artifact digest linked to this gate result when present.", "x-data-class": "public" },
    "normalized_input_digests": { "type": "array", "maxItems": 64, "uniqueItems": true, "description": "Declared normalized gate input digests bound to the evaluated gate result.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Digest identity.", "x-data-class": "public" } },
    "details": { "type": "object", "maxProperties": 32, "description": "Optional bounded advisory details.", "x-data-class": "public", "additionalProperties": true }
  }
}
