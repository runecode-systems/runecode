{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstratePostureGetResponse.schema.json",
  "title": "ProjectSubstratePostureGetResponse",
  "description": "Broker-owned typed posture and lifecycle diagnostics surface for project substrate.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 11,
  "required": ["schema_id", "schema_version", "request_id", "repository_root", "contract", "snapshot", "posture_summary", "adoption", "init_preview", "upgrade_preview"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstratePostureGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "repository_root": { "type": "string", "minLength": 1, "maxLength": 4096, "description": "Authoritative repository root used for posture diagnostics.", "x-data-class": "public" },
    "contract": { "$ref": "ProjectSubstrateContractState.schema.json", "description": "Active canonical project-substrate contract.", "x-data-class": "public" },
    "snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Read-only validation snapshot for discovered substrate posture.", "x-data-class": "public" },
    "posture_summary": { "$ref": "ProjectSubstratePostureSummary.schema.json", "description": "Compatibility summary projected for readiness/version and operator status surfaces.", "x-data-class": "public" },
    "adoption": { "$ref": "ProjectSubstrateAdoptionResult.schema.json", "description": "Broker-projected adoption posture for canonical existing substrate.", "x-data-class": "public" },
    "init_preview": { "$ref": "ProjectSubstrateInitPreview.schema.json", "description": "Broker-projected initialization preview posture.", "x-data-class": "public" },
    "upgrade_preview": { "$ref": "ProjectSubstrateUpgradePreview.schema.json", "description": "Broker-projected upgrade/remediation preview posture.", "x-data-class": "public" },
    "blocked_explanation": { "type": "string", "minLength": 1, "maxLength": 1024, "description": "Broker-projected blocked-state explanation when normal operation is not allowed.", "x-data-class": "public" },
    "remediation_guidance": {
      "type": "array",
      "maxItems": 32,
      "description": "Broker-projected remediation and follow-up guidance codes.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Guidance code.", "x-data-class": "public" }
    }
  }
}
