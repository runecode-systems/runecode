{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalDetail.schema.json",
  "title": "ApprovalDetail",
  "description": "Typed broker-projected approval detail model for review surfaces.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 12,
  "required": ["schema_id", "schema_version", "approval_id", "lifecycle_detail", "binding_kind", "what_changes_if_approved", "blocked_work_scope", "bound_identity"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalDetail", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "approval_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Canonical approval identity hash.", "x-data-class": "public" },
    "policy_reason_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Machine reason code describing policy outcome semantics for this approval.", "x-data-class": "public" },
    "lifecycle_detail": { "$ref": "ApprovalLifecycleDetail.schema.json", "description": "Typed lifecycle reason/detail semantics for review surfaces.", "x-data-class": "public" },
    "binding_kind": { "type": "string", "enum": ["exact_action", "stage_sign_off"], "description": "Explicit approval binding kind.", "x-data-class": "public" },
    "bound_action_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Canonical ActionRequest hash when binding_kind is exact_action.", "x-data-class": "public" },
    "bound_stage_summary_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Canonical stage summary hash when binding_kind is stage_sign_off.", "x-data-class": "public" },
    "what_changes_if_approved": { "$ref": "ApprovalWhatChangesIfApproved.schema.json", "description": "Structured explanation of the effect when approval is granted.", "x-data-class": "public" },
    "blocked_work_scope": { "$ref": "ApprovalBlockedWorkScope.schema.json", "description": "Typed scope for work currently blocked pending this approval.", "x-data-class": "public" },
    "bound_identity": { "$ref": "ApprovalBoundIdentity.schema.json", "description": "Typed bound identity detail for request/decision verification context.", "x-data-class": "public" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "binding_kind": { "const": "exact_action" }
        }
      },
      "then": {
        "required": ["bound_action_hash"]
      }
    },
    {
      "if": {
        "properties": {
          "binding_kind": { "const": "stage_sign_off" }
        }
      },
      "then": {
        "required": ["bound_stage_summary_hash"]
      }
    }
  ]
}
