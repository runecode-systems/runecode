{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalResolveResponse.schema.json",
  "title": "ApprovalResolveResponse",
  "description": "Typed approval resolve response with structured status metadata and optional approved artifact summary.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 7,
  "required": ["schema_id", "schema_version", "request_id", "resolution_status", "approval"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalResolveResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "resolution_status": { "type": "string", "enum": ["resolved", "no_change"], "description": "Structured resolve status.", "x-data-class": "public" },
    "resolution_reason_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Optional machine-readable resolution reason code.", "x-data-class": "public" },
    "approval": { "$ref": "ApprovalSummary.schema.json", "description": "Resolved approval summary.", "x-data-class": "public" },
    "approved_artifact": { "$ref": "ArtifactSummary.schema.json", "description": "Optional approved artifact summary.", "x-data-class": "public" }
  }
}
