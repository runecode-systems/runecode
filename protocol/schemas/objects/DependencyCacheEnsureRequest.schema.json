{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/DependencyCacheEnsureRequest.schema.json",
  "title": "DependencyCacheEnsureRequest",
  "description": "Broker-owned request to ensure lockfile-derived dependency batch availability through authoritative cache lookup, miss coalescing, fetch execution, verification, and CAS persistence.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": ["schema_id", "schema_version", "request_id", "run_id", "batch_request"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.DependencyCacheEnsureRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request correlation identifier.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Broker run identity for audit linkage; non-authoritative for cache keying.", "x-data-class": "public" },
    "batch_request": { "$ref": "DependencyFetchBatchRequest.schema.json", "description": "Canonical typed lockfile-bound dependency batch identity.", "x-data-class": "public" }
  }
}
