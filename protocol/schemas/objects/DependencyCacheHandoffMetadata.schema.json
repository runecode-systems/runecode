{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/DependencyCacheHandoffMetadata.schema.json",
  "title": "DependencyCacheHandoffMetadata",
  "description": "Broker-authoritative dependency handoff metadata for offline consumption without exposing local paths or credentials.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": ["schema_id", "schema_version", "request_digest", "resolved_unit_digest", "manifest_digest", "payload_digests", "materialization_mode", "handoff_mode"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.DependencyCacheHandoffMetadata", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical dependency request digest identity.", "x-data-class": "public" },
    "resolved_unit_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Resolved unit digest identity.", "x-data-class": "public" },
    "manifest_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Resolved-unit manifest artifact digest.", "x-data-class": "public" },
    "payload_digests": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "$ref": "Digest.schema.json#/$defs/digestValue" }, "description": "Dependency payload artifact digests for handoff.", "x-data-class": "public" },
    "materialization_mode": { "type": "string", "enum": ["derived_read_only"], "description": "Materialization posture for downstream consumer derivation.", "x-data-class": "public" },
    "handoff_mode": { "type": "string", "enum": ["broker_internal_artifact_handoff"], "description": "Broker-authoritative handoff mode.", "x-data-class": "public" }
  }
}
