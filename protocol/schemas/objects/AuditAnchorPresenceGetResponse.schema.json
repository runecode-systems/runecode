{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditAnchorPresenceGetResponse.schema.json",
  "title": "AuditAnchorPresenceGetResponse",
  "description": "Broker-owned local response with signer presence mode and optional attestation for audit anchoring.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "seal_digest", "presence_mode"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.AuditAnchorPresenceGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Echoed request identifier.", "x-data-class": "public" },
    "seal_digest": { "$ref": "AuditRecordDigest.schema.json#/$defs/auditRecordDigestValue", "description": "Digest identity of the targeted segment seal.", "x-data-class": "public" },
    "presence_mode": { "type": "string", "enum": ["os_confirmation", "hardware_touch", "passphrase"], "description": "Resolved signer presence mode for this broker-owned anchor path.", "x-data-class": "public" },
    "presence_attestation": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": ["challenge", "acknowledgment_token"],
      "properties": {
        "challenge": { "type": "string", "minLength": 16, "maxLength": 256, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Broker-generated challenge nonce for local user presence.", "x-data-class": "public" },
        "acknowledgment_token": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[a-f0-9]{64}$", "description": "Broker-generated acknowledgment token bound to presence_mode, seal_digest, and challenge.", "x-data-class": "public" }
      },
      "description": "Present when signer presence mode requires explicit user presence attestation.",
      "x-data-class": "public"
    }
  }
}
