{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/BrokerArtifactPutResponse.schema.json",
  "title": "BrokerArtifactPutResponse",
  "description": "Typed broker artifact-put response family with request correlation and resulting reference.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "artifact"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.BrokerArtifactPutResponse",
      "description": "Stable protocol object-family identifier for artifact put responses.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Exact protocol schema version used to validate this artifact put response.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request identifier copied from the request.",
      "x-data-class": "public"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 5,
      "required": ["digest", "size_bytes", "content_type", "data_class", "provenance_receipt_hash"],
      "properties": {
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Artifact digest.", "x-data-class": "public" },
        "size_bytes": { "type": "integer", "minimum": 0, "maximum": 1099511627776, "description": "Artifact size in bytes.", "x-data-class": "public" },
        "content_type": { "type": "string", "minLength": 1, "maxLength": 256, "description": "Artifact content type.", "x-data-class": "public" },
        "data_class": { "type": "string", "enum": ["spec_text", "unapproved_file_excerpts", "approved_file_excerpts", "diffs", "build_logs", "audit_events", "audit_verification_report", "audit_receipt_export_copy", "gate_evidence", "web_query", "web_citations"], "description": "Artifact data class.", "x-data-class": "public" },
        "provenance_receipt_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Artifact provenance receipt hash.", "x-data-class": "public" }
      },
      "description": "Artifact reference minted by the put operation.",
      "x-data-class": "sensitive"
    }
  }
}
