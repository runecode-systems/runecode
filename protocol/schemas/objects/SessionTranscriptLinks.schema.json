{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionTranscriptLinks.schema.json",
  "title": "SessionTranscriptLinks",
  "description": "Typed related-object links attached to transcript items.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "run_ids", "approval_ids", "artifact_digests", "audit_record_digests"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionTranscriptLinks", "description": "Protocol schema identifier for SessionTranscriptLinks.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for SessionTranscriptLinks.", "x-data-class": "public" },
    "run_ids": { "type": "array", "maxItems": 256, "description": "Run identities linked to the transcript item in stable deterministic order.", "x-data-class": "public", "items": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Run identifier.", "x-data-class": "public" } },
    "approval_ids": { "type": "array", "maxItems": 512, "description": "Approval identities linked to the transcript item in stable deterministic order.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Approval digest identity.", "x-data-class": "public" } },
    "artifact_digests": { "type": "array", "maxItems": 1024, "description": "Artifact digest identities linked to the transcript item in stable deterministic order.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Artifact digest identity.", "x-data-class": "public" } },
    "audit_record_digests": { "type": "array", "maxItems": 1024, "description": "Audit-record digest identities linked to the transcript item in stable deterministic order.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Audit-record digest identity.", "x-data-class": "public" } }
  }
}
