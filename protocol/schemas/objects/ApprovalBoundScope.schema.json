{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalBoundScope.schema.json",
  "title": "ApprovalBoundScope",
  "description": "Normalized machine-readable approval bound scope metadata.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 9,
  "required": ["schema_id", "schema_version", "action_kind"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalBoundScope", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound workspace identifier.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound run identifier.", "x-data-class": "public" },
    "stage_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound stage identifier.", "x-data-class": "public" },
    "step_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound step identifier.", "x-data-class": "public" },
    "role_instance_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound role instance identifier.", "x-data-class": "public" },
    "action_kind": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound action kind.", "x-data-class": "public" },
    "policy_decision_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Policy decision digest bound to this approval scope.", "x-data-class": "public" }
  }
}
