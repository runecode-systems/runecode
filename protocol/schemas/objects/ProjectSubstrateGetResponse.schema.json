{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateGetResponse.schema.json",
  "title": "ProjectSubstrateGetResponse",
  "description": "Typed response with discovered canonical project-substrate state.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "repository_root", "contract", "snapshot"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "repository_root": { "type": "string", "minLength": 1, "maxLength": 4096, "description": "Authoritative repository root used for discovery.", "x-data-class": "public" },
    "contract": { "$ref": "ProjectSubstrateContractState.schema.json", "description": "Active canonical project-substrate contract.", "x-data-class": "public" },
    "snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Read-only validation snapshot for discovered canonical substrate posture.", "x-data-class": "public" }
  }
}
