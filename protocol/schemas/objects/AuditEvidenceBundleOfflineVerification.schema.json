{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceBundleOfflineVerification.schema.json",
  "title": "AuditEvidenceBundleOfflineVerification",
  "description": "Offline verification result for an exported audit evidence bundle based on bundle manifest and included objects only.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 13,
  "required": ["schema_id", "schema_version", "verified_at", "archive_format", "scope", "verifier_identity", "verification_status"],
  "$defs": {
    "offlineFinding": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 5,
      "description": "Offline verification finding entry.",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z][a-z0-9_]*$", "description": "Machine-readable offline finding code.", "x-data-class": "public" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"], "description": "Severity classification for the finding.", "x-data-class": "public" },
        "message": { "type": "string", "minLength": 1, "maxLength": 2048, "description": "Human-readable finding detail.", "x-data-class": "public" },
        "object_path": { "type": "string", "minLength": 1, "maxLength": 2048, "description": "Bundle path for the affected object when available.", "x-data-class": "public" },
        "digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Digest identity associated with the finding when available.", "x-data-class": "public" }
      }
    },
    "reportPosture": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 8,
      "description": "Projected posture summary for one verification report object.",
      "required": ["digest", "integrity_status", "anchoring_status", "storage_posture_status", "segment_lifecycle_status", "currently_degraded"],
      "properties": {
        "digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Digest identity for the verification report payload.", "x-data-class": "public" },
        "integrity_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Projected integrity status from the report.", "x-data-class": "public" },
        "anchoring_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Projected anchoring status from the report.", "x-data-class": "public" },
        "storage_posture_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Projected storage-posture status from the report.", "x-data-class": "public" },
        "segment_lifecycle_status": { "type": "string", "enum": ["ok", "degraded", "failed"], "description": "Projected segment-lifecycle status from the report.", "x-data-class": "public" },
        "currently_degraded": { "type": "boolean", "description": "Whether the report explicitly marks current degradation.", "x-data-class": "public" },
        "degraded_reasons": { "type": "array", "maxItems": 256, "items": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z][a-z0-9_]*$" }, "description": "Reported degradation reasons.", "x-data-class": "public" },
        "hard_failures": { "type": "array", "maxItems": 256, "items": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z][a-z0-9_]*$" }, "description": "Reported hard-failure reason codes.", "x-data-class": "public" }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceBundleOfflineVerification",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "verified_at": {
      "type": "string",
      "maxLength": 64,
      "format": "date-time",
      "description": "Verification timestamp.",
      "x-data-class": "public"
    },
    "archive_format": {
      "type": "string",
      "enum": ["tar"],
      "description": "Verified archive format.",
      "x-data-class": "public"
    },
    "manifest_digest": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Canonical digest identity of manifest content.",
      "x-data-class": "public"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Bundle identifier from manifest.",
      "x-data-class": "public"
    },
    "export_profile": {
      "type": "string",
      "enum": ["operator_private_full", "company_internal_audit", "external_relying_party_minimal", "incident_response_scope"],
      "description": "Manifest export profile.",
      "x-data-class": "public"
    },
    "scope": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/scope",
      "description": "Manifest scope.",
      "x-data-class": "public"
    },
    "verifier_identity": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/verifierIdentity",
      "description": "Manifest verifier identity.",
      "x-data-class": "public"
    },
    "trust_root_digests": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "Digest.schema.json#/$defs/digestValue" },
      "description": "Manifest trust-root identities.",
      "x-data-class": "public"
    },
    "verification_status": {
      "type": "string",
      "enum": ["ok", "degraded", "failed"],
      "description": "Aggregate offline verification outcome.",
      "x-data-class": "public"
    },
    "findings": {
      "type": "array",
      "maxItems": 2048,
      "items": { "$ref": "#/$defs/offlineFinding" },
      "description": "Offline verification findings, including missing evidence and degraded posture visibility.",
      "x-data-class": "public"
    },
    "verification_reports": {
      "type": "array",
      "maxItems": 512,
      "items": { "$ref": "#/$defs/reportPosture" },
      "description": "Projected posture summaries for included verification reports.",
      "x-data-class": "public"
    }
  }
}
