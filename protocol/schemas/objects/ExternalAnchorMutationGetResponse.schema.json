{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ExternalAnchorMutationGetResponse.schema.json",
  "title": "ExternalAnchorMutationGetResponse",
  "description": "Get response returning authoritative prepared external anchor mutation state.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "prepared"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ExternalAnchorMutationGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier echoed from request.",
      "x-data-class": "public"
    },
    "prepared": { "$ref": "ExternalAnchorMutationPreparedState.schema.json", "description": "Durable prepared mutation state record.", "x-data-class": "public" }
  }
}
