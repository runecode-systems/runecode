{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/RuntimeImageSignedPayload.schema.json",
  "title": "RuntimeImageSignedPayload",
  "description": "Canonical signed payload for runtime-image identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": ["schema_id", "schema_version", "backend_kind", "platform_compatibility", "boot_contract_version", "component_digests"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.RuntimeImageSignedPayload", "description": "Protocol schema identifier for canonical runtime-image signed payload bytes.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for canonical runtime-image signed payload bytes.", "x-data-class": "public" },
    "backend_kind": { "type": "string", "enum": ["microvm", "container"], "description": "Backend topology kind for compatibility checking.", "x-data-class": "public" },
    "platform_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture"],
      "maxProperties": 3,
      "description": "Backend-neutral runtime platform compatibility constraints.",
      "x-data-class": "public",
      "properties": {
        "os": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9][a-z0-9._-]*$", "description": "Target guest operating system family.", "x-data-class": "public" },
        "architecture": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9][a-z0-9._-]*$", "description": "Target guest CPU architecture.", "x-data-class": "public" },
        "acceleration_kind": { "type": "string", "enum": ["kvm", "hvf", "whpx", "none"], "description": "Optional acceleration compatibility hint.", "x-data-class": "public" }
      }
    },
    "boot_contract_version": { "type": "string", "enum": ["microvm-linux-kernel-initrd-v1", "container-oci-image-v1"], "description": "Closed boot profile identifier.", "x-data-class": "public" },
    "component_digests": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 16,
      "description": "Digest-addressed concrete boot components keyed by logical component name.",
      "x-data-class": "public",
      "additionalProperties": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Digest identity for one component.", "x-data-class": "public" }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 2,
      "description": "Optional future-facing attestation and measurement linkage hooks.",
      "x-data-class": "public",
      "properties": {
        "measurement_profile": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Measurement profile identifier.", "x-data-class": "public" },
        "expected_measurement_digests": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "x-data-class": "public" },
          "description": "Optional list of expected measurement digest anchors.",
          "x-data-class": "public"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "backend_kind": { "const": "microvm" } },
        "required": ["backend_kind"]
      },
      "then": {
        "properties": {
          "component_digests": {
            "required": ["kernel", "initrd"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "backend_kind": { "const": "container" } },
        "required": ["backend_kind"]
      },
      "then": {
        "properties": {
          "component_digests": {
            "required": ["image"]
          }
        }
      }
    }
  ]
}
