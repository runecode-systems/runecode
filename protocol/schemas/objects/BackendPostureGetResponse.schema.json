{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/BackendPostureGetResponse.schema.json",
  "title": "BackendPostureGetResponse",
  "description": "Typed response carrying current backend posture state.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "posture"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.BackendPostureGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Echoed request identifier.", "x-data-class": "public" },
    "posture": { "$ref": "BackendPostureState.schema.json", "description": "Current backend posture state.", "x-data-class": "public" }
  }
}
