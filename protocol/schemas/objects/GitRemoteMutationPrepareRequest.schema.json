{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitRemoteMutationPrepareRequest.schema.json",
  "title": "GitRemoteMutationPrepareRequest",
  "description": "Prepare request for broker-local git remote mutation control-plane using authoritative typed request object.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 7,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "run_id",
    "provider",
    "typed_request"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GitRemoteMutationPrepareRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier.",
      "x-data-class": "public"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Run identifier to evaluate prepare policy context.",
      "x-data-class": "public"
    },
    "provider": { "type": "string", "minLength": 1, "maxLength": 64, "description": "Git provider requested for mutation execution.", "x-data-class": "public" },
    "destination_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9.-]+(?::(?:6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3}))?(?:/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*)?$",
      "description": "Canonical destination reference when explicitly supplied.",
      "x-data-class": "sensitive"
    },
    "typed_request": {
      "oneOf": [
        { "$ref": "GitRefUpdateRequest.schema.json" },
        { "$ref": "GitPullRequestCreateRequest.schema.json" }
      ],
      "description": "Authoritative provider-neutral typed request object.",
      "x-data-class": "public"
    }
  }
}
