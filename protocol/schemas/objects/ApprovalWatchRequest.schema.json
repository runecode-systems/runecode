{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalWatchRequest.schema.json",
  "title": "ApprovalWatchRequest",
  "description": "Typed approval watch request with follow and snapshot semantics for transport-neutral live UX.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "request_id", "stream_id", "follow", "include_snapshot"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalWatchRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request identifier.", "x-data-class": "public" },
    "stream_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable stream identifier.", "x-data-class": "public" },
    "approval_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Optional approval identity filter.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional run scope filter.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional workspace scope filter.", "x-data-class": "public" },
    "status": { "type": "string", "enum": ["pending", "approved", "denied", "expired", "cancelled", "superseded", "consumed"], "description": "Optional approval status filter.", "x-data-class": "public" },
    "follow": { "type": "boolean", "description": "Whether to continue streaming new approval updates.", "x-data-class": "public" },
    "include_snapshot": { "type": "boolean", "description": "Whether to include an initial approval snapshot event before live updates.", "x-data-class": "public" }
  }
}
