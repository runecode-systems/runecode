{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GateEvidence.schema.json",
  "title": "GateEvidence",
  "description": "Typed canonical gate-evidence summary object for one gate attempt. Reference-heavy by design.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 23,
  "required": [
    "schema_id",
    "schema_version",
    "gate_id",
    "gate_kind",
    "gate_version",
    "run_id",
    "gate_attempt_id",
    "started_at",
    "finished_at",
    "runtime",
    "outcome"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GateEvidence", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "gate_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Stable gate identity.", "x-data-class": "public" },
    "gate_kind": { "type": "string", "enum": ["build", "test", "lint", "format", "secret_scan", "policy"], "description": "Gate taxonomy kind.", "x-data-class": "public" },
    "gate_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$", "maxLength": 32, "description": "Gate contract version.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable run identity.", "x-data-class": "public" },
    "stage_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable stage identity when known.", "x-data-class": "public" },
    "step_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable step identity when known.", "x-data-class": "public" },
    "role_instance_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Stable role-instance identity when known.", "x-data-class": "public" },
    "gate_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Gate attempt identity (separate from workflow scope IDs).", "x-data-class": "public" },
    "plan_checkpoint_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Plan-derived checkpoint placement identity for this gate attempt.", "x-data-class": "public" },
    "plan_order_index": { "type": "integer", "minimum": 0, "description": "Plan-derived deterministic gate placement order index for this gate attempt.", "x-data-class": "public" },
    "started_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Gate execution start timestamp.", "x-data-class": "public" },
    "finished_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Gate execution finish timestamp.", "x-data-class": "public" },
    "normalized_input_digests": { "type": "array", "maxItems": 64, "uniqueItems": true, "description": "Declared normalized gate input digests.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Digest identity.", "x-data-class": "public" } },
    "runtime": { "type": "object", "minProperties": 1, "maxProperties": 64, "description": "Tool/runtime identity and deterministic execution context summary.", "x-data-class": "public", "additionalProperties": true },
    "outcome": { "type": "object", "minProperties": 1, "maxProperties": 64, "description": "Deterministic gate outcome summary.", "x-data-class": "public", "additionalProperties": true },
    "output_artifact_digests": { "type": "array", "maxItems": 64, "uniqueItems": true, "description": "Referenced bulky output/log artifact digests.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Digest identity.", "x-data-class": "public" } },
    "policy_decision_refs": { "type": "array", "maxItems": 64, "uniqueItems": true, "description": "Related policy decision digest refs.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Policy decision digest identity.", "x-data-class": "public" } },
    "overridden_failed_result_ref": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Failed gate result identity linked when overridden.", "x-data-class": "public" },
    "override_action_request_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Canonical gate-override action request hash when override continuation is used.", "x-data-class": "public" },
    "override_policy_decision_ref": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Linked policy decision digest authorizing override continuation.", "x-data-class": "public" },
    "failure_reason_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128, "description": "Normalized failure reason code when applicable.", "x-data-class": "public" }
  }
}
