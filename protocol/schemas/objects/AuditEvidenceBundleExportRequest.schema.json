{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceBundleExportRequest.schema.json",
  "title": "AuditEvidenceBundleExportRequest",
  "description": "Typed request to stream an audit evidence bundle archive with manifest-driven scope/profile selection.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 9,
  "required": ["schema_id", "schema_version", "request_id", "scope", "export_profile", "created_by_tool", "disclosure_posture"],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceBundleExportRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request identifier.",
      "x-data-class": "public"
    },
    "scope": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/scope",
      "description": "Bundle scope declaration.",
      "x-data-class": "public"
    },
    "export_profile": {
      "type": "string",
      "enum": ["operator_private_full", "company_internal_audit", "external_relying_party_minimal", "incident_response_scope"],
      "description": "Requested export profile.",
      "x-data-class": "public"
    },
    "created_by_tool": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/toolIdentity",
      "description": "Creating tool identity.",
      "x-data-class": "public"
    },
    "disclosure_posture": {
      "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/disclosurePosture",
      "description": "Requested disclosure posture declaration.",
      "x-data-class": "public"
    },
    "redactions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "description": "Optional redaction list declared for this export.",
      "x-data-class": "public",
      "items": {
        "$ref": "AuditEvidenceBundleManifest.schema.json#/$defs/redaction",
        "description": "One declared redaction entry."
      }
    },
    "archive_format": {
      "type": "string",
      "enum": ["tar"],
      "description": "Requested streaming archive format.",
      "x-data-class": "public"
    }
  }
}
