{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderProfileGetResponse.schema.json",
  "title": "ProviderProfileGetResponse",
  "description": "Typed response carrying a broker-projected provider profile inspection view.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "profile"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderProfileGetResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request correlation identifier.", "x-data-class": "public" },
    "profile": { "$ref": "ProviderProfile.schema.json", "description": "Broker-projected provider profile setup/readiness/compatibility posture.", "x-data-class": "public" }
  }
}
