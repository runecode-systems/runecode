{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitSetupIdentityUpsertRequest.schema.json",
  "title": "GitSetupIdentityUpsertRequest",
  "description": "Typed request to create or update a broker-managed git commit identity profile.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": ["schema_id", "schema_version", "request_id", "provider", "profile"],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GitSetupIdentityUpsertRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier.",
      "x-data-class": "public"
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Git provider whose broker-managed identity profile set is being updated.",
      "x-data-class": "public"
    },
    "profile": {
      "$ref": "GitCommitIdentityProfile.schema.json",
      "description": "Broker-managed commit identity profile to create or update.",
      "x-data-class": "public"
    }
  }
}
