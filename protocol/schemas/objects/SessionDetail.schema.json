{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionDetail.schema.json",
  "title": "SessionDetail",
  "description": "Broker detail-facing session model sufficient for alpha chat-route hydration with ordered transcript turn/message contracts.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": ["schema_id", "schema_version", "summary", "transcript_turns", "linked_run_ids", "linked_approval_ids", "linked_artifact_digests", "linked_audit_record_digests"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionDetail", "description": "Protocol schema identifier for SessionDetail.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for SessionDetail.", "x-data-class": "public" },
    "summary": { "$ref": "SessionSummary.schema.json", "description": "List-facing session summary baseline.", "x-data-class": "public" },
    "transcript_turns": { "type": "array", "maxItems": 2048, "description": "Ordered transcript turns in monotonic turn_index order for this session.", "x-data-class": "public", "items": { "$ref": "SessionTranscriptTurn.schema.json", "description": "Transcript turn entry.", "x-data-class": "public" } },
    "linked_run_ids": { "type": "array", "maxItems": 256, "description": "Stable run identities linked to this session in deterministic order.", "x-data-class": "public", "items": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Run identifier.", "x-data-class": "public" } },
    "linked_approval_ids": { "type": "array", "maxItems": 512, "description": "Stable approval identities linked to this session.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Approval digest identity.", "x-data-class": "public" } },
    "linked_artifact_digests": { "type": "array", "maxItems": 1024, "description": "Artifact digest identities linked to this session.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Artifact digest identity.", "x-data-class": "public" } },
    "linked_audit_record_digests": { "type": "array", "maxItems": 1024, "description": "Audit record digest identities linked to this session.", "x-data-class": "public", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Audit record digest identity.", "x-data-class": "public" } }
  }
}
