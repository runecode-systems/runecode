{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceBundleManifest.schema.json",
  "title": "AuditEvidenceBundleManifest",
  "description": "Portable evidence-bundle manifest describing bundle scope, export posture, included objects, root digests, seal references, verifier identity, trust roots, and disclosure posture. This manifest is not a substitute for underlying evidence objects.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 20,
  "required": [
    "schema_id",
    "schema_version",
    "bundle_id",
    "created_at",
    "created_by_tool",
    "export_profile",
    "scope",
    "verifier_identity",
    "disclosure_posture"
  ],
  "$defs": {
    "digestList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "uniqueItems": true,
      "description": "Sorted, unique digest identity list.",
      "x-data-class": "public",
      "items": {
        "$ref": "Digest.schema.json#/$defs/digestValue",
        "description": "One canonical digest identity.",
        "x-data-class": "public"
      }
    },
    "toolIdentity": {
      "description": "Identity metadata for the tool that produced the bundle manifest.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["tool_name", "tool_version"],
      "properties": {
        "tool_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Tool identity that produced this manifest.",
          "x-data-class": "public"
        },
        "tool_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Tool version that produced this manifest.",
          "x-data-class": "public"
        },
        "build_revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Optional build revision for the creating tool.",
          "x-data-class": "public"
        },
        "protocol_bundle_manifest_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Protocol bundle manifest hash used by the creating tool.",
          "x-data-class": "public"
        }
      }
    },
    "scope": {
      "description": "Declared scope selector controlling which evidence subset is exported.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["scope_kind"],
      "properties": {
        "scope_kind": {
          "type": "string",
          "enum": ["run", "artifact", "incident", "auditor_minimal", "operator_private", "external_relying_party"],
          "description": "Bundle scope shape.",
          "x-data-class": "public"
        },
        "run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Run identifier when scope is run-like.",
          "x-data-class": "public"
        },
        "incident_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Incident identifier when scope is incident-like.",
          "x-data-class": "public"
        },
        "artifact_digests": {
          "$ref": "#/$defs/digestList",
          "description": "Artifact digests included by artifact scope.",
          "x-data-class": "public"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scope_kind": {
                "const": "run"
              }
            },
            "required": ["scope_kind"]
          },
          "then": {
            "required": ["run_id"]
          }
        },
        {
          "if": {
            "properties": {
              "scope_kind": {
                "const": "artifact"
              }
            },
            "required": ["scope_kind"]
          },
          "then": {
            "required": ["artifact_digests"]
          }
        },
        {
          "if": {
            "properties": {
              "scope_kind": {
                "const": "incident"
              }
            },
            "required": ["scope_kind"]
          },
          "then": {
            "required": ["incident_id"]
          }
        }
      ]
    },
    "controlPlaneProvenance": {
      "description": "Control-plane provenance digests captured when authoritative identities are available.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 6,
      "properties": {
        "workflow_definition_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Workflow definition digest identity when available from trusted control-plane evidence.",
          "x-data-class": "public"
        },
        "tool_manifest_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Tool manifest digest identity when available and policy permits.",
          "x-data-class": "public"
        },
        "prompt_template_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Prompt or template digest identity when available and policy permits.",
          "x-data-class": "public"
        },
        "protocol_bundle_manifest_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Protocol bundle manifest digest identity used for control-plane bindings.",
          "x-data-class": "public"
        },
        "verifier_implementation_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Verifier implementation digest identity when available from trusted verifier material.",
          "x-data-class": "public"
        },
        "trust_policy_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Trust-policy digest identity used by verifier contract inputs when available.",
          "x-data-class": "public"
        }
      }
    },
    "includedObject": {
      "description": "Portable descriptor for one object included in the evidence bundle.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["object_family", "digest", "path", "byte_length"],
      "properties": {
        "object_family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "enum": ["audit_segment", "audit_segment_seal", "audit_receipt", "audit_verification_report", "external_anchor_evidence", "external_anchor_sidecar", "event_contract_catalog", "verifier_record_set", "signer_evidence", "storage_posture"],
          "description": "Included object family.",
          "x-data-class": "public"
        },
        "digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical digest for this object.",
          "x-data-class": "public"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^[A-Za-z0-9._/-]+$",
          "description": "Portable bundle path for this object.",
          "x-data-class": "public"
        },
        "byte_length": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991,
          "description": "Object byte length for streaming verification planning.",
          "x-data-class": "public"
        }
      }
    },
    "sealReference": {
      "description": "Reference to a segment seal needed for integrity and chronology validation.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["segment_id", "seal_digest", "seal_chain_index"],
      "properties": {
        "segment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Sealed segment identifier.",
          "x-data-class": "public"
        },
        "seal_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Segment seal digest identity.",
          "x-data-class": "public"
        },
        "seal_chain_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000000,
          "description": "Seal chain index for this segment seal.",
          "x-data-class": "public"
        },
        "previous_seal_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Previous linked seal digest when available.",
          "x-data-class": "public"
        }
      }
    },
    "verifierIdentity": {
      "description": "Verifier identity descriptor for included verification artifacts.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["key_id", "key_id_value", "logical_purpose", "logical_scope"],
      "properties": {
        "key_id": {
          "type": "string",
          "const": "key_sha256",
          "description": "Verifier key-id profile.",
          "x-data-class": "public"
        },
        "key_id_value": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "description": "Verifier key-id value.",
          "x-data-class": "public"
        },
        "logical_purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Verifier logical purpose.",
          "x-data-class": "public"
        },
        "logical_scope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Verifier logical scope.",
          "x-data-class": "public"
        }
      }
    },
    "disclosurePosture": {
      "description": "Disclosure posture declaration and selective-disclosure marker for this export.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": ["posture", "selective_disclosure_applied"],
      "properties": {
        "posture": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Disclosure posture used for this export.",
          "x-data-class": "public"
        },
        "selective_disclosure_applied": {
          "type": "boolean",
          "description": "Whether selective disclosure shaping was applied.",
          "x-data-class": "public"
        }
      }
    },
    "redaction": {
      "description": "One redaction applied to the exported bundle projection.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": ["path", "reason_code"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "description": "Bundle-relative path redacted from export output.",
          "x-data-class": "public"
        },
        "reason_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Redaction reason code.",
          "x-data-class": "public"
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceBundleManifest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable bundle identifier for this manifest instance.",
      "x-data-class": "public"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64,
      "description": "RFC 3339 timestamp when this bundle manifest was created.",
      "x-data-class": "public"
    },
    "created_by_tool": {
      "$ref": "#/$defs/toolIdentity",
      "description": "Tool identity that produced this manifest.",
      "x-data-class": "public"
    },
    "export_profile": {
      "type": "string",
      "enum": ["operator_private_full", "company_internal_audit", "external_relying_party_minimal", "incident_response_scope"],
      "description": "Declared export profile for this bundle.",
      "x-data-class": "public"
    },
    "scope": {
      "$ref": "#/$defs/scope",
      "description": "Scope declaration for this bundle.",
      "x-data-class": "public"
    },
    "repository_identity_digest": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Repository/project identity digest bound by trusted local context when available.",
      "x-data-class": "public"
    },
    "product_instance_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^repo-[a-z0-9]+$",
      "description": "Stable repo-scoped product instance identity for this bundle projection.",
      "x-data-class": "public"
    },
    "ledger_identity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^ledger-[a-f0-9]+$",
      "description": "Persistent audit ledger identity for the source evidence ledger.",
      "x-data-class": "public"
    },
    "control_plane_provenance": {
      "$ref": "#/$defs/controlPlaneProvenance",
      "description": "Control-plane provenance digest identities captured for this bundle when available.",
      "x-data-class": "public"
    },
    "project_context_identity_digest": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Project-context identity digest preserved for portable provenance identity.",
      "x-data-class": "public"
    },
    "included_objects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "description": "Included object list with family, digest, path, and size.",
      "x-data-class": "public",
      "items": {
        "$ref": "#/$defs/includedObject",
        "description": "One included object descriptor."
      }
    },
    "root_digests": {
      "$ref": "#/$defs/digestList",
      "description": "Root digest identities needed for incremental verification.",
      "x-data-class": "public"
    },
    "seal_references": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "description": "Segment seal references included by this bundle.",
      "x-data-class": "public",
      "items": {
        "$ref": "#/$defs/sealReference",
        "description": "One segment seal reference."
      }
    },
    "verifier_identity": {
      "$ref": "#/$defs/verifierIdentity",
      "description": "Verifier identity used for included verification artifacts.",
      "x-data-class": "public"
    },
    "trust_root_digests": {
      "$ref": "#/$defs/digestList",
      "description": "Verifier trust-root digests used for included verification artifacts.",
      "x-data-class": "public"
    },
    "disclosure_posture": {
      "$ref": "#/$defs/disclosurePosture",
      "description": "Disclosure posture applied to this export.",
      "x-data-class": "public"
    },
    "redactions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "description": "Redaction list applied during selective disclosure, when present.",
      "x-data-class": "public",
      "items": {
        "$ref": "#/$defs/redaction",
        "description": "One redaction entry."
      }
    }
  }
}
