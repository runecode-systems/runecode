{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditEvidenceRetentionReviewResponse.schema.json",
  "title": "AuditEvidenceRetentionReviewResponse",
  "description": "Trusted local response carrying preservation snapshot, portable bundle manifest projection, and retention/backfill completeness review.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "snapshot", "manifest", "completeness_review"],
  "$defs": {
    "snapshotIdentity": {
      "description": "One identity entry in completeness-review output.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": ["family"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Evidence family name.",
          "x-data-class": "public"
        },
        "identity": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Evidence digest identity where the family is digest-addressed.",
          "x-data-class": "public"
        }
      }
    },
    "completenessReview": {
      "description": "Snapshot-versus-bundle completeness review result.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["fully_satisfied", "required_identity_count"],
      "properties": {
        "fully_satisfied": {
          "type": "boolean",
          "description": "True when all required identities were found in exported canonical evidence.",
          "x-data-class": "public"
        },
        "required_identity_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000,
          "description": "Total number of required identities checked for completeness.",
          "x-data-class": "public"
        },
        "missing": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000000,
          "description": "Required identities missing from the export package.",
          "x-data-class": "public",
          "items": {
            "$ref": "#/$defs/snapshotIdentity",
            "description": "One missing required identity."
          }
        },
        "declared_redactions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000000,
          "description": "Required identities omitted by explicit declared redaction posture.",
          "x-data-class": "public",
          "items": {
            "$ref": "#/$defs/snapshotIdentity",
            "description": "One redacted required identity."
          }
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditEvidenceRetentionReviewResponse",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Echoed request identifier.",
      "x-data-class": "public"
    },
    "snapshot": {
      "$ref": "AuditEvidenceSnapshot.schema.json",
      "description": "Preservation snapshot used as completeness baseline.",
      "x-data-class": "public"
    },
    "manifest": {
      "$ref": "AuditEvidenceBundleManifest.schema.json",
      "description": "Canonical bundle manifest projection used for completeness comparison.",
      "x-data-class": "public"
    },
    "completeness_review": {
      "$ref": "#/$defs/completenessReview",
      "description": "Retention/backfill completeness review output.",
      "x-data-class": "public"
    }
  }
}
