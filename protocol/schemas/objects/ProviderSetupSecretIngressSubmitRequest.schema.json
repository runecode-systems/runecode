{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderSetupSecretIngressSubmitRequest.schema.json",
  "title": "ProviderSetupSecretIngressSubmitRequest",
  "description": "Typed secret-ingress submission metadata. Raw secret material travels outside ordinary typed request fields.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id", "secret_ingress_token"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderSetupSecretIngressSubmitRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Request correlation identifier.", "x-data-class": "public" },
    "secret_ingress_token": { "type": "string", "minLength": 1, "maxLength": 128, "description": "One-time secret ingress token.", "x-data-class": "public" }
  }
}
