{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionTranscriptMessage.schema.json",
  "title": "SessionTranscriptMessage",
  "description": "Typed transcript message contract with stable identity and explicit in-turn ordering semantics.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "message_id", "turn_id", "session_id", "message_index", "role", "created_at", "content_text", "related_links"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionTranscriptMessage", "description": "Protocol schema identifier for SessionTranscriptMessage.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version for SessionTranscriptMessage.", "x-data-class": "public" },
    "message_id": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable message identity scoped to the session transcript.", "x-data-class": "public" },
    "turn_id": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Turn identity containing this message.", "x-data-class": "public" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Canonical session identity for this message.", "x-data-class": "public" },
    "message_index": { "type": "integer", "minimum": 1, "description": "Monotonic one-based message order within its turn.", "x-data-class": "public" },
    "role": { "type": "string", "enum": ["user", "assistant", "system", "tool"], "description": "Transcript role for this message.", "x-data-class": "public" },
    "created_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Message timestamp in RFC3339 format.", "x-data-class": "public" },
    "content_text": { "type": "string", "maxLength": 32768, "description": "Primary display text for this transcript message.", "x-data-class": "public" },
    "related_links": { "$ref": "SessionTranscriptLinks.schema.json", "description": "Typed links to related runs, approvals, artifacts, and audit records.", "x-data-class": "public" }
  }
}
