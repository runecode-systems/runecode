{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionTurnExecution.schema.json",
  "title": "SessionTurnExecution",
  "description": "Broker-owned durable per-turn execution state projection, distinct from transcript turn lifecycle.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 27,
  "required": ["schema_id", "schema_version", "turn_id", "session_id", "execution_index", "trigger_id", "trigger_source", "requested_operation", "execution_state", "approval_profile", "autonomy_posture", "created_at", "updated_at"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionTurnExecution", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "turn_id": { "type": "string", "minLength": 1, "maxLength": 160, "description": "Canonical turn-execution identity.", "x-data-class": "public" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Canonical session identity.", "x-data-class": "public" },
    "execution_index": { "type": "integer", "minimum": 1, "description": "Monotonic per-session execution index.", "x-data-class": "public" },
    "orchestration_scope_id": { "type": "string", "minLength": 1, "maxLength": 160, "description": "Broker-owned orchestration scope identity for dependency-aware partial blocking.", "x-data-class": "public" },
    "depends_on_scope_ids": { "type": "array", "maxItems": 256, "description": "Orchestration scope dependencies that must resolve before this scope can proceed.", "items": { "type": "string", "minLength": 1, "maxLength": 160, "description": "Dependent orchestration scope identity.", "x-data-class": "public" }, "x-data-class": "public" },
    "trigger_id": { "type": "string", "minLength": 1, "maxLength": 160, "description": "Canonical execution trigger identity.", "x-data-class": "public" },
    "trigger_source": { "type": "string", "enum": ["interactive_user", "autonomous_background", "resume_follow_up"], "description": "Explanatory trigger source classification.", "x-data-class": "public" },
    "requested_operation": { "type": "string", "enum": ["start", "continue"], "description": "Requested execution operation.", "x-data-class": "public" },
    "execution_state": { "type": "string", "enum": ["queued", "planning", "running", "waiting", "blocked", "failed", "completed"], "description": "Broker-owned turn execution lifecycle state.", "x-data-class": "public" },
    "wait_kind": { "type": "string", "enum": ["operator_input", "approval", "external_dependency", "project_blocked"], "description": "Machine-typed wait kind while execution_state=waiting.", "x-data-class": "public" },
    "wait_state": { "type": "string", "enum": ["waiting_operator_input", "waiting_approval", "waiting_external_dependency", "waiting_project_blocked"], "description": "Operator-facing waiting vocabulary, preserving approval vs operator input distinction.", "x-data-class": "public" },
    "approval_profile": { "type": "string", "enum": ["moderate"], "description": "Formal approval frequency control.", "x-data-class": "public" },
    "autonomy_posture": { "type": "string", "enum": ["operator_guided", "balanced", "autonomous_preferred"], "description": "Operator-question frequency and continuation posture control.", "x-data-class": "public" },
    "primary_run_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Primary canonical run linked to this turn when present.", "x-data-class": "public" },
    "pending_approval_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Pending approval digest identity when present.", "x-data-class": "public" },
    "linked_run_ids": { "type": "array", "maxItems": 256, "description": "Canonical linked run identities.", "items": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Linked run identity.", "x-data-class": "public" }, "x-data-class": "public" },
    "linked_approval_ids": { "type": "array", "maxItems": 512, "description": "Canonical linked approval identities.", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Linked approval digest identity.", "x-data-class": "public" }, "x-data-class": "public" },
    "linked_artifact_digests": { "type": "array", "maxItems": 1024, "description": "Linked artifact digests.", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Linked artifact digest.", "x-data-class": "public" }, "x-data-class": "public" },
    "linked_audit_record_digests": { "type": "array", "maxItems": 1024, "description": "Linked audit record digests.", "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Linked audit record digest.", "x-data-class": "public" }, "x-data-class": "public" },
    "bound_validated_project_substrate_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Validated project substrate snapshot digest bound for execution-sensitive context.", "x-data-class": "public" },
    "blocked_reason_code": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9_.-]{0,127}$", "maxLength": 128, "description": "Stable blocked reason code when execution is blocked.", "x-data-class": "public" },
    "terminal_outcome": { "type": "string", "enum": ["completed", "failed", "cancelled"], "description": "Terminal outcome when execution ends.", "x-data-class": "public" },
    "created_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Creation timestamp for this turn-execution state record.", "x-data-class": "public" },
    "updated_at": { "type": "string", "format": "date-time", "maxLength": 64, "description": "Last update timestamp for this turn-execution state record.", "x-data-class": "public" }
  }
}
