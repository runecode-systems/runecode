{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitPullRequestCreateRequest.schema.json",
  "title": "GitPullRequestCreateRequest",
  "description": "Provider-neutral typed pull-request creation request bound to base/head repository refs and approved patch-flow result identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 12,
  "required": [
    "schema_id",
    "schema_version",
    "request_kind",
    "base_repository_identity",
    "base_ref",
    "head_repository_identity",
    "head_ref",
    "title",
    "body",
    "head_commit_or_tree_hash",
    "referenced_patch_artifact_digests",
    "expected_result_tree_hash"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GitPullRequestCreateRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_kind": {
      "type": "string",
      "enum": [
        "git_pull_request_create"
      ],
      "description": "Provider-neutral git request family.",
      "x-data-class": "public"
    },
    "base_repository_identity": {
      "$ref": "DestinationDescriptor.schema.json",
      "description": "Logical base repository identity.",
      "x-data-class": "public"
    },
    "base_ref": {
      "type": "string",
      "minLength": 6,
      "maxLength": 256,
      "pattern": "^refs/[A-Za-z0-9._/-]+$",
      "description": "Canonical base ref for the pull request.",
      "x-data-class": "public"
    },
    "head_repository_identity": {
      "$ref": "DestinationDescriptor.schema.json",
      "description": "Logical head repository identity.",
      "x-data-class": "public"
    },
    "head_ref": {
      "type": "string",
      "minLength": 6,
      "maxLength": 256,
      "pattern": "^refs/[A-Za-z0-9._/-]+$",
      "description": "Canonical head ref for the pull request.",
      "x-data-class": "public"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Pull-request title metadata.",
      "x-data-class": "public"
    },
    "body": {
      "type": "string",
      "maxLength": 65536,
      "description": "Pull-request body metadata.",
      "x-data-class": "public"
    },
    "head_commit_or_tree_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Head commit or tree identity produced by approved patch flow.",
      "x-data-class": "public"
    },
    "referenced_patch_artifact_digests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "description": "Signed patch artifact digests consumed by this request.",
      "x-data-class": "public",
      "items": {
        "$ref": "Digest.schema.json#/$defs/digestValue"
      }
    },
    "expected_result_tree_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Expected tree hash corresponding to approved outbound mutation state.",
      "x-data-class": "public"
    }
  }
}
