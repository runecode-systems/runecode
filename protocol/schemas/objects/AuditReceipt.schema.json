{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditReceipt.schema.json",
  "title": "AuditReceipt",
  "description": "Protocol-owned unsigned audit receipt payload family for signed sidecar attestations over signed audit objects, including import/restore provenance evidence without segment-byte rewrites.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 11,
  "$defs": {
    "importedSegmentLink": {
      "description": "One imported or restored historical segment linkage proving sealed-byte identity and binding local provenance to prior sealed evidence.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 5,
      "required": [
        "imported_segment_seal_digest",
        "imported_segment_root",
        "source_segment_file_hash",
        "local_segment_file_hash",
        "byte_identity_verified"
      ],
      "properties": {
        "imported_segment_seal_digest": {
          "$ref": "AuditRecordDigest.schema.json#/$defs/auditRecordDigestValue",
          "description": "Digest of the imported signed AuditSegmentSeal envelope for this historical segment.",
          "x-data-class": "public"
        },
        "imported_segment_root": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Ordered Merkle root recorded by the imported segment seal for this segment.",
          "x-data-class": "public"
        },
        "source_segment_file_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Exact hash of raw framed bytes from the source imported/backup segment file.",
          "x-data-class": "public"
        },
        "local_segment_file_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Exact hash of raw framed bytes as stored locally after import or restore.",
          "x-data-class": "public"
        },
        "byte_identity_verified": {
          "const": true,
          "description": "Fail-closed byte-identity assertion: local segment bytes are identical to imported sealed source bytes.",
          "x-data-class": "public"
        }
      }
    },
    "authorityContext": {
      "description": "Optional operator or authority context for import/restore provenance admission.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": [
        "authority_kind",
        "authority_id"
      ],
      "properties": {
        "authority_kind": {
          "type": "string",
          "enum": [
            "operator",
            "system_policy",
            "external_authority"
          ],
          "description": "Authority category responsible for admitting this import/restore evidence.",
          "x-data-class": "public"
        },
        "authority_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Stable authority identifier for operational provenance review.",
          "x-data-class": "public"
        },
        "authorization_manifest_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Optional digest reference for policy/manifest evidence that authorized this import or restore.",
          "x-data-class": "public"
        },
        "note": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional non-secret operator-facing authority context note.",
          "x-data-class": "public"
        }
      }
    },
    "importRestoreProvenancePayload": {
      "description": "Typed import/restore/reconciliation provenance payload binding historical segment linkage and source-manifest evidence while preserving sealed byte identity.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 7,
      "required": [
        "provenance_action",
        "segment_file_hash_scope",
        "imported_segments",
        "source_manifest_digests"
      ],
      "properties": {
        "provenance_action": {
          "type": "string",
          "enum": [
            "import",
            "restore",
            "reconciliation"
          ],
          "description": "Operation kind proven by this receipt payload.",
          "x-data-class": "public"
        },
        "segment_file_hash_scope": {
          "const": "raw_framed_segment_bytes_v1",
          "description": "Pinned segment-byte hash scope used to prove source/local byte identity for imported or restored segments.",
          "x-data-class": "public"
        },
        "imported_segments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "description": "Historical sealed segments covered by this provenance evidence payload.",
          "x-data-class": "public",
          "items": {
            "$ref": "#/$defs/importedSegmentLink",
            "description": "One imported or restored segment provenance linkage."
          },
          "uniqueItems": true
        },
        "source_manifest_digests": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "description": "Digest references for source backup/export manifests or inventories that enumerated imported segments.",
          "x-data-class": "public",
          "items": {
            "$ref": "Digest.schema.json#/$defs/digestValue",
            "description": "One source backup or export manifest digest."
          },
          "uniqueItems": true
        },
        "operator": {
          "$ref": "PrincipalIdentity.schema.json",
          "description": "Optional operator identity associated with this import/restore action where human operation context applies.",
          "x-data-class": "sensitive"
        },
        "authority_context": {
          "$ref": "#/$defs/authorityContext",
          "description": "Optional authority context for policy- or authority-mediated import/restore admission.",
          "x-data-class": "public"
        },
        "source_instance_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Optional source instance identifier from which sealed segments were imported or restored.",
          "x-data-class": "public"
        }
      }
    },
    "anchorWitness": {
      "description": "Typed witness payload for anchor acts. MVP verification currently admits local user-presence witness kinds while preserving additive witness-kind extension in this shared anchor receipt family.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": [
        "witness_kind",
        "witness_digest"
      ],
      "properties": {
        "witness_kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Typed witness discriminator for anchor evidence payloads.",
          "x-data-class": "public"
        },
        "witness_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest reference to sidecar evidence proving the local anchor act.",
          "x-data-class": "public"
        }
      }
    },
    "anchorExternalProof": {
      "description": "Typed proof reference for external anchor families. Proof bytes stay in authoritative sidecar evidence and are referenced by digest.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 3,
      "required": [
        "proof_kind",
        "proof_schema_id",
        "proof_digest"
      ],
      "properties": {
        "proof_kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Typed proof discriminator for external anchor evidence sidecars.",
          "x-data-class": "public"
        },
        "proof_schema_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Schema ID for the external proof sidecar payload.",
          "x-data-class": "public"
        },
        "proof_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest of the authoritative external proof sidecar evidence object.",
          "x-data-class": "public"
        }
      }
    },
    "anchorExternalTransparencyLogTargetDescriptor": {
      "description": "Typed transparency-log target descriptor used to define canonical target identity without binding policy to raw transport URLs.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": [
        "descriptor_schema_id",
        "log_id",
        "log_public_key_digest",
        "entry_encoding_profile"
      ],
      "properties": {
        "descriptor_schema_id": {
          "const": "runecode.protocol.audit.anchor_target.transparency_log.v0",
          "description": "Typed schema discriminator for transparency-log target descriptors.",
          "x-data-class": "public"
        },
        "log_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Stable transparency-log identity, independent from transport URL.",
          "x-data-class": "public"
        },
        "log_public_key_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest of the transparency-log public verification key.",
          "x-data-class": "public"
        },
        "entry_encoding_profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Entry encoding profile expected for transparency-log proof validation.",
          "x-data-class": "public"
        }
      }
    },
    "anchorExternalTimestampAuthorityTargetDescriptor": {
      "description": "Typed timestamp-authority target descriptor used to define canonical target identity without binding policy to raw transport URLs.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": [
        "descriptor_schema_id",
        "authority_id",
        "certificate_chain_digest",
        "timestamp_profile"
      ],
      "properties": {
        "descriptor_schema_id": {
          "const": "runecode.protocol.audit.anchor_target.timestamp_authority.v0",
          "description": "Typed schema discriminator for timestamp-authority target descriptors.",
          "x-data-class": "public"
        },
        "authority_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Stable timestamp-authority identity, independent from transport endpoint URL.",
          "x-data-class": "public"
        },
        "certificate_chain_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest of the trusted certificate-chain material for timestamp verification.",
          "x-data-class": "public"
        },
        "timestamp_profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Timestamp token profile used for validation.",
          "x-data-class": "public"
        }
      }
    },
    "anchorExternalPublicChainTargetDescriptor": {
      "description": "Typed public-chain target descriptor used to define canonical target identity without binding policy to raw transport URLs.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": [
        "descriptor_schema_id",
        "chain_namespace",
        "network_id",
        "settlement_contract_digest"
      ],
      "properties": {
        "descriptor_schema_id": {
          "const": "runecode.protocol.audit.anchor_target.public_chain.v0",
          "description": "Typed schema discriminator for public-chain target descriptors.",
          "x-data-class": "public"
        },
        "chain_namespace": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Public-chain namespace (for example EVM-family).",
          "x-data-class": "public"
        },
        "network_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Stable public-chain network identity.",
          "x-data-class": "public"
        },
        "settlement_contract_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest of contract identity material defining anchoring settlement rules.",
          "x-data-class": "public"
        }
      }
    },
    "anchorExternalPayload": {
      "description": "Typed external anchor binding that keeps transport-specific endpoints as derived execution details and target identity as a canonical typed descriptor digest.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 6,
      "required": [
        "target_kind",
        "runtime_adapter",
        "target_descriptor",
        "target_descriptor_digest",
        "proof"
      ],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "transparency_log",
            "timestamp_authority",
            "public_chain"
          ],
          "description": "Typed external target family.",
          "x-data-class": "public"
        },
        "runtime_adapter": {
          "type": "string",
          "enum": [
            "transparency_log_v0"
          ],
          "description": "Concrete runtime adapter binding. `transparency_log_v0` is the frozen first adapter in this grouping.",
          "x-data-class": "public"
        },
        "target_descriptor": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 6,
          "description": "Typed target descriptor object. Canonical descriptor digest is the authoritative target identity.",
          "x-data-class": "public"
        },
        "target_descriptor_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical RFC 8785 JCS digest of target_descriptor, used as authoritative target identity.",
          "x-data-class": "public"
        },
        "proof": {
          "$ref": "#/$defs/anchorExternalProof",
          "description": "Typed proof reference to authoritative sidecar evidence.",
          "x-data-class": "public"
        },
        "derived_execution": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 4,
          "description": "Optional transport-specific execution details that are derived below typed target identity.",
          "x-data-class": "sensitive"
        }
      }
    },
    "anchorReceiptPayload": {
      "description": "Typed anchor payload binding either local presence witness fields or additive typed external anchor fields while preserving the shared AuditReceipt(kind=anchor) envelope.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 7,
      "required": [
        "anchor_kind"
      ],
      "properties": {
        "anchor_kind": {
          "type": "string",
          "enum": [
            "local_user_presence_signature",
            "external_transparency_log_v0",
            "external_timestamp_authority_v0",
            "external_public_chain_v0"
          ],
          "description": "Machine-consumed anchor target kind for this receipt payload. Transparency-log style external anchoring is the first concrete adapter family; timestamp-authority and public-chain remain additive typed follow-on families.",
          "x-data-class": "public"
        },
        "key_protection_posture": {
          "type": "string",
          "enum": [
            "hardware_backed",
            "os_keystore",
            "passphrase_wrapped",
            "ephemeral_memory"
          ],
          "description": "Signer key-protection posture recorded for local anchor acts.",
          "x-data-class": "public"
        },
        "presence_mode": {
          "type": "string",
          "enum": [
            "os_confirmation",
            "passphrase",
            "hardware_touch"
          ],
          "description": "Presence mode used for local anchor acts.",
          "x-data-class": "public"
        },
        "approval_assurance_level": {
          "type": "string",
          "enum": [
            "none",
            "session_authenticated",
            "reauthenticated",
            "hardware_backed"
          ],
          "description": "Optional assurance level from linked approval context when policy required approval.",
          "x-data-class": "public"
        },
        "approval_decision_digest": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Optional digest identity of the signed ApprovalDecision consumed before anchoring.",
          "x-data-class": "public"
        },
        "anchor_witness": {
          "$ref": "#/$defs/anchorWitness",
          "description": "Typed witness payload proving local anchor act itself.",
          "x-data-class": "public"
        },
        "external_anchor": {
          "$ref": "#/$defs/anchorExternalPayload",
          "description": "Typed external anchor payload with canonical target descriptor digest and sidecar proof reference.",
          "x-data-class": "public"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "anchor_kind": {
                "const": "local_user_presence_signature"
              }
            },
            "required": [
              "anchor_kind"
            ]
          },
          "then": {
            "required": [
              "key_protection_posture",
              "presence_mode",
              "anchor_witness"
            ],
            "not": {
              "required": [
                "external_anchor"
              ]
            },
            "properties": {
              "anchor_witness": {
                "properties": {
                  "witness_kind": {
                    "const": "local_user_presence_signature_v0"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "anchor_kind": {
                "const": "external_transparency_log_v0"
              }
            },
            "required": [
              "anchor_kind"
            ]
          },
          "then": {
            "required": [
              "external_anchor"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "key_protection_posture"
                  ]
                },
                {
                  "required": [
                    "presence_mode"
                  ]
                },
                {
                  "required": [
                    "anchor_witness"
                  ]
                }
              ]
            },
            "properties": {
              "external_anchor": {
                "properties": {
                  "target_kind": {
                    "const": "transparency_log"
                  },
                  "proof": {
                    "properties": {
                      "proof_kind": {
                        "const": "transparency_log_receipt_v0"
                      },
                      "proof_schema_id": {
                        "const": "runecode.protocol.audit.anchor_proof.transparency_log_receipt.v0"
                      }
                    }
                  },
                  "target_descriptor": {
                    "$ref": "#/$defs/anchorExternalTransparencyLogTargetDescriptor"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "anchor_kind": {
                "const": "external_timestamp_authority_v0"
              }
            },
            "required": [
              "anchor_kind"
            ]
          },
          "then": {
            "required": [
              "external_anchor"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "key_protection_posture"
                  ]
                },
                {
                  "required": [
                    "presence_mode"
                  ]
                },
                {
                  "required": [
                    "anchor_witness"
                  ]
                }
              ]
            },
            "properties": {
              "external_anchor": {
                "properties": {
                  "target_kind": {
                    "const": "timestamp_authority"
                  },
                  "proof": {
                    "properties": {
                      "proof_kind": {
                        "const": "timestamp_token_v0"
                      },
                      "proof_schema_id": {
                        "const": "runecode.protocol.audit.anchor_proof.timestamp_token.v0"
                      }
                    }
                  },
                  "target_descriptor": {
                    "$ref": "#/$defs/anchorExternalTimestampAuthorityTargetDescriptor"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "anchor_kind": {
                "const": "external_public_chain_v0"
              }
            },
            "required": [
              "anchor_kind"
            ]
          },
          "then": {
            "required": [
              "external_anchor"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "key_protection_posture"
                  ]
                },
                {
                  "required": [
                    "presence_mode"
                  ]
                },
                {
                  "required": [
                    "anchor_witness"
                  ]
                }
              ]
            },
            "properties": {
              "external_anchor": {
                "properties": {
                  "target_kind": {
                    "const": "public_chain"
                  },
                  "proof": {
                    "properties": {
                      "proof_kind": {
                        "const": "public_chain_tx_receipt_v0"
                      },
                      "proof_schema_id": {
                        "const": "runecode.protocol.audit.anchor_proof.public_chain_tx_receipt.v0"
                      }
                    }
                  },
                  "target_descriptor": {
                    "$ref": "#/$defs/anchorExternalPublicChainTargetDescriptor"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "approval_decision_digest"
            ]
          },
          "then": {
            "required": [
              "approval_assurance_level"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "approval_assurance_level": {
                "const": "none"
              }
            },
            "required": [
              "approval_assurance_level"
            ]
          },
          "then": {
            "not": {
              "required": [
                "approval_decision_digest"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "approval_assurance_level": {
                "const": "hardware_backed"
              }
            },
            "required": [
              "approval_assurance_level"
            ]
          },
          "then": {
            "required": [
              "approval_decision_digest"
            ],
            "properties": {
              "anchor_kind": {
                "const": "local_user_presence_signature"
              },
              "presence_mode": {
                "const": "hardware_touch"
              },
              "key_protection_posture": {
                "const": "hardware_backed"
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "receipt_payload"
        ]
      },
      "then": {
        "required": [
          "receipt_payload_schema_id"
        ]
      }
    },
    {
      "if": {
        "required": [
          "receipt_payload_schema_id"
        ]
      },
      "then": {
        "required": [
          "receipt_payload"
        ]
      }
    },
    {
      "if": {
        "required": [
          "audit_receipt_kind"
        ],
        "properties": {
          "audit_receipt_kind": {
            "const": "anchor"
          }
        }
      },
      "then": {
        "required": [
          "receipt_payload_schema_id",
          "receipt_payload"
        ],
        "properties": {
          "receipt_payload_schema_id": {
            "const": "runecode.protocol.audit.receipt.anchor.v0"
          },
          "receipt_payload": {
            "$ref": "#/$defs/anchorReceiptPayload"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "audit_receipt_kind"
        ],
        "properties": {
          "audit_receipt_kind": {
            "enum": [
              "import",
              "restore",
              "reconciliation"
            ]
          }
        }
      },
      "then": {
        "required": [
          "receipt_payload_schema_id",
          "receipt_payload"
        ],
        "properties": {
          "receipt_payload_schema_id": {
            "const": "runecode.protocol.audit.receipt.import_restore_provenance.v0"
          },
          "receipt_payload": {
            "$ref": "#/$defs/importRestoreProvenancePayload"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "audit_receipt_kind"
        ],
        "properties": {
          "audit_receipt_kind": {
            "const": "reconciliation"
          }
        }
      },
      "then": {
        "properties": {
          "receipt_payload": {
            "properties": {
              "provenance_action": {
                "const": "reconciliation"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "audit_receipt_kind"
        ],
        "properties": {
          "audit_receipt_kind": {
            "const": "import"
          }
        }
      },
      "then": {
        "properties": {
          "receipt_payload": {
            "properties": {
              "provenance_action": {
                "const": "import"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "audit_receipt_kind"
        ],
        "properties": {
          "audit_receipt_kind": {
            "const": "restore"
          }
        }
      },
      "then": {
        "properties": {
          "receipt_payload": {
            "properties": {
              "provenance_action": {
                "const": "restore"
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "schema_id",
    "schema_version",
    "subject_digest",
    "audit_receipt_kind",
    "recorder",
    "recorded_at"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.AuditReceipt",
      "description": "Stable protocol object-family identifier for audit receipts.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.5.0",
      "description": "Exact protocol schema version used to validate this audit receipt.",
      "x-data-class": "public"
    },
