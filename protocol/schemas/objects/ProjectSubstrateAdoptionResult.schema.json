{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateAdoptionResult.schema.json",
  "title": "ProjectSubstrateAdoptionResult",
  "description": "Read-only adoption outcome for discovered canonical project substrate.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "repository_root", "status", "snapshot"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateAdoptionResult", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "repository_root": { "type": "string", "minLength": 1, "maxLength": 4096, "description": "Authoritative repository root evaluated for adoption.", "x-data-class": "public" },
    "status": { "type": "string", "enum": ["adopted", "blocked"], "description": "Adoption status for discovered canonical substrate posture.", "x-data-class": "public" },
    "reason_codes": {
      "type": "array",
      "maxItems": 32,
      "description": "Stable reason codes when adoption is blocked.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Deterministic adoption reason code.", "x-data-class": "public" }
    },
    "snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Validation snapshot used for adoption decision.", "x-data-class": "public" }
  }
}
