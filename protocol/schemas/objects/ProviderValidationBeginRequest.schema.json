{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderValidationBeginRequest.schema.json",
  "title": "ProviderValidationBeginRequest",
  "description": "Broker-owned request to begin provider validation/revalidation lifecycle progression.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "required": ["schema_id", "schema_version", "request_id", "provider_profile_id"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderValidationBeginRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request correlation identifier.", "x-data-class": "public" },
    "provider_profile_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Provider profile identifier being validated.", "x-data-class": "public" },
    "validation_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional caller-supplied validation attempt identity.", "x-data-class": "public" },
    "validation_reason": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9_:-]+$", "description": "Optional stable reason code for validation trigger semantics.", "x-data-class": "public" }
  }
}
