{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/BackendPostureChangeResponse.schema.json",
  "title": "BackendPostureChangeResponse",
  "description": "Typed response for backend posture change requests.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 5,
  "required": ["schema_id", "schema_version", "request_id", "outcome", "posture"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.BackendPostureChangeResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Echoed request identifier.", "x-data-class": "public" },
    "outcome": { "$ref": "BackendPostureChangeOutcome.schema.json", "description": "Change outcome envelope.", "x-data-class": "public" },
    "posture": { "$ref": "BackendPostureState.schema.json", "description": "Latest posture snapshot after this request.", "x-data-class": "public" }
  }
}
