{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/DependencyCacheEnsureResponse.schema.json",
  "title": "DependencyCacheEnsureResponse",
  "description": "Broker-owned dependency cache ensure result with authoritative cache outcome and canonical artifact references.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": ["schema_id", "schema_version", "request_id", "batch_request_hash", "batch_manifest_digest", "resolution_state", "cache_outcome", "resolved_unit_digests", "fetched_bytes", "registry_request_count"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.DependencyCacheEnsureResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request correlation identifier.", "x-data-class": "public" },
    "batch_request_hash": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Canonical digest of the typed DependencyFetchBatchRequest.", "x-data-class": "public" },
    "batch_manifest_digest": { "$ref": "Digest.schema.json#/$defs/digestValue", "description": "Digest of stored dependency batch manifest artifact.", "x-data-class": "public" },
    "resolution_state": { "type": "string", "enum": ["complete"], "description": "Fail-closed resolution state.", "x-data-class": "public" },
    "cache_outcome": { "type": "string", "enum": ["hit_exact", "miss_filled"], "description": "Authoritative cache result classification.", "x-data-class": "public" },
    "resolved_unit_digests": { "type": "array", "minItems": 1, "maxItems": 4096, "uniqueItems": true, "items": { "$ref": "Digest.schema.json#/$defs/digestValue" }, "description": "Canonical resolved-unit digest set for this batch.", "x-data-class": "public" },
    "fetched_bytes": { "type": "integer", "minimum": 0, "maximum": 1099511627776, "description": "Total bytes fetched from registry during this ensure operation.", "x-data-class": "public" },
    "registry_request_count": { "type": "integer", "minimum": 0, "maximum": 4096, "description": "Registry request count executed after miss coalescing.", "x-data-class": "public" }
  }
}
