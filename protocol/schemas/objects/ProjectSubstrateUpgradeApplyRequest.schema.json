{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateUpgradeApplyRequest.schema.json",
  "title": "ProjectSubstrateUpgradeApplyRequest",
  "description": "Typed request for explicit project-substrate upgrade apply.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": ["schema_id", "schema_version", "request_id"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateUpgradeApplyRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "expected_preview_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Expected upgrade preview digest from reviewed preview intent.", "x-data-class": "public" }
  }
}
