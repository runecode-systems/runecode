{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitSignedPatchArtifact.schema.json",
  "title": "GitSignedPatchArtifact",
  "description": "Typed signed git patch artifact metadata bound to canonical patch payload identity in the diffs data class.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": [
    "schema_id",
    "schema_version",
    "data_class",
    "base_commit_hash",
    "base_tree_hash",
    "canonical_patch_payload_hash",
    "touched_paths",
    "expected_result_tree_hash"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GitSignedPatchArtifact",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "data_class": {
      "const": "diffs",
      "description": "Patch artifacts stay in the shared diffs data class.",
      "x-data-class": "public"
    },
    "base_commit_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Base commit hash for patch application.",
      "x-data-class": "public"
    },
    "base_tree_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Base repository tree hash for patch application.",
      "x-data-class": "public"
    },
    "canonical_patch_payload_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Canonical patch payload hash for the referenced diff bytes.",
      "x-data-class": "public"
    },
    "touched_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2048,
      "uniqueItems": true,
      "description": "Deterministic touched-path inventory extracted from the canonical patch.",
      "x-data-class": "public",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024,
        "pattern": "^[A-Za-z0-9._~!$&'()*+,;=:@%-](?:[A-Za-z0-9._~!$&'()*+,;=:@%/-]*[A-Za-z0-9._~!$&'()*+,;=:@%-])?$",
        "description": "Canonical repository-relative touched path."
      }
    },
    "expected_result_tree_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Expected repository tree hash after applying the canonical patch payload.",
      "x-data-class": "public"
    },
    "patch_format": {
      "type": "string",
      "enum": [
        "unified_diff"
      ],
      "description": "Canonical patch payload format.",
      "x-data-class": "public"
    },
    "patch_strip_components": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8,
      "description": "Optional strip-components count for deterministic patch application.",
      "x-data-class": "public"
    }
  }
}
