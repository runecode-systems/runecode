{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/AuditTimelineResponse.schema.json",
  "title": "AuditTimelineResponse",
  "description": "Typed audit operational timeline response page with stable record linkage for drill-down reads.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 6,
  "$defs": {
    "linkedReference": {
      "description": "One typed linked reference surfaced from broker-owned audit timeline views.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "required": ["reference_kind", "reference_id"],
      "properties": {
        "reference_kind": {
          "type": "string",
          "enum": ["approval", "artifact", "audit_record", "verification_reason"],
          "description": "Linked reference family for this timeline entry.",
          "x-data-class": "public"
        },
        "reference_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^(sha256:[a-f0-9]{64}|[a-z][a-z0-9_]*)$",
          "description": "Stable linked reference identity in broker-visible form.",
          "x-data-class": "public"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional operator-facing linked-reference label.",
          "x-data-class": "public"
        },
        "relation": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Optional machine-consumed relation hint.",
          "x-data-class": "public"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reference_kind": { "const": "approval" }
            },
            "required": ["reference_kind"]
          },
          "then": {
            "properties": {
              "reference_id": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$",
                "maxLength": 71
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reference_kind": { "const": "artifact" }
            },
            "required": ["reference_kind"]
          },
          "then": {
            "properties": {
              "reference_id": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$",
                "maxLength": 71
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reference_kind": { "const": "audit_record" }
            },
            "required": ["reference_kind"]
          },
          "then": {
            "properties": {
              "reference_id": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$",
                "maxLength": 71
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reference_kind": { "const": "verification_reason" }
            },
            "required": ["reference_kind"]
          },
          "then": {
            "properties": {
              "reference_id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$",
                "maxLength": 128
              }
            }
          }
        }
      ]
    },
    "verificationPosture": {
      "description": "Optional record-facing verification posture derived from broker-owned verification views.",
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "required": ["status", "reason_codes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "degraded", "failed"],
          "description": "Derived verification posture for this timeline entry.",
          "x-data-class": "public"
        },
        "reason_codes": {
          "type": "array",
          "maxItems": 64,
          "description": "Stable reason codes from verification findings relevant to this timeline entry.",
          "x-data-class": "public",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "One verification reason code.",
            "x-data-class": "public"
          },
          "uniqueItems": true
        }
      }
    },
    "viewEntry": {
      "description": "Audit operational view entry carrying stable identity linkage for drill-down reads.",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_digest"],
      "properties": {
        "record_digest": {
          "$ref": "AuditRecordDigest.schema.json#/$defs/auditRecordDigestValue",
          "description": "Stable audit-record identity used for timeline-to-detail drill-down.",
          "x-data-class": "public"
        },
        "project_context_identity_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "maxLength": 71,
          "description": "Validated project-context identity digest bound to canonical project-substrate snapshot identity used for this timeline projection.",
          "x-data-class": "public"
        },
        "event_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Audit event type when this timeline view maps an audit_event record.",
          "x-data-class": "public"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^[^\u0000-\u001F\u007F]+$",
          "description": "Concise broker-derived timeline summary for operator inspection.",
          "x-data-class": "public"
        },
        "linked_references": {
          "type": "array",
          "maxItems": 128,
          "description": "Typed linked references useful for approval, artifact, and verification pivots.",
          "x-data-class": "public",
          "items": {
            "$ref": "#/$defs/linkedReference",
            "description": "One linked reference entry."
          }
        },
        "verification_posture": {
          "$ref": "#/$defs/verificationPosture",
          "description": "Optional derived verification posture for this timeline entry.",
          "x-data-class": "public"
        }
      },
      "maxProperties": 128,
      "description": "Audit operational view entry.",
      "x-data-class": "public"
    }
  },
  "required": ["schema_id", "schema_version", "request_id", "order", "views"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.AuditTimelineResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable echoed request identifier.", "x-data-class": "public" },
    "order": { "type": "string", "enum": ["operational_seq_asc", "operational_seq_desc"], "description": "Ordering applied to this timeline page.", "x-data-class": "public" },
    "views": { "type": "array", "maxItems": 500, "description": "Audit operational view page entries.", "x-data-class": "public", "items": { "$ref": "#/$defs/viewEntry", "description": "Audit operational view entry." } },
    "next_cursor": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Opaque continuation cursor.", "x-data-class": "public" }
  }
}
