{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadGateOverride.schema.json",
  "title": "ActionPayloadGateOverride",
  "description": "Typed action payload for gate override operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 12,
  "required": [
    "schema_id",
    "schema_version",
    "gate_id",
    "gate_kind",
    "gate_version",
    "gate_attempt_id",
    "overridden_failed_result_ref",
    "policy_context_hash",
    "override_mode",
    "justification"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadGateOverride",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "gate_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "maxLength": 128,
      "description": "Target stable gate identity.",
      "x-data-class": "public"
    },
    "gate_kind": {
      "type": "string",
      "enum": [
        "build",
        "test",
        "lint",
        "format",
        "secret_scan",
        "policy"
      ],
      "description": "Target gate taxonomy kind.",
      "x-data-class": "public"
    },
    "gate_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "maxLength": 32,
      "description": "Target gate contract version.",
      "x-data-class": "public"
    },
    "gate_attempt_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Exact failed gate attempt identity that this override targets.",
      "x-data-class": "public"
    },
    "overridden_failed_result_ref": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "maxLength": 71,
      "description": "Canonical failed gate result digest that this override continuation references.",
      "x-data-class": "public"
    },
    "policy_context_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "maxLength": 71,
      "description": "Current effective policy context hash bound to this override request.",
      "x-data-class": "public"
    },
    "override_mode": {
      "type": "string",
      "enum": [
        "temporary_allow",
        "break_glass"
      ],
      "description": "Override mode.",
      "x-data-class": "public"
    },
    "justification": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Required operator justification.",
      "x-data-class": "sensitive"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64,
      "description": "Optional override expiry timestamp.",
      "x-data-class": "public"
    },
    "ticket_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Optional audit or incident ticket reference.",
      "x-data-class": "public"
    }
  }
}
