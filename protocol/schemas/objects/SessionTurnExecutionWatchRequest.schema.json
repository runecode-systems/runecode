{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SessionTurnExecutionWatchRequest.schema.json",
  "title": "SessionTurnExecutionWatchRequest",
  "description": "Typed session turn execution watch request with follow and snapshot semantics for broker-owned execution-state read models.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 11,
  "required": ["schema_id", "schema_version", "request_id", "stream_id", "follow", "include_snapshot"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.SessionTurnExecutionWatchRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request identifier.", "x-data-class": "public" },
    "stream_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable stream identifier.", "x-data-class": "public" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional session identity filter.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Optional workspace scope filter.", "x-data-class": "public" },
    "turn_id": { "type": "string", "minLength": 1, "maxLength": 160, "description": "Optional turn execution identity filter.", "x-data-class": "public" },
    "execution_state": { "type": "string", "enum": ["queued", "planning", "running", "waiting", "blocked", "failed", "completed"], "description": "Optional execution-state filter.", "x-data-class": "public" },
    "wait_kind": { "type": "string", "enum": ["operator_input", "approval", "external_dependency", "project_blocked"], "description": "Optional wait-kind filter.", "x-data-class": "public" },
    "follow": { "type": "boolean", "description": "Whether to continue streaming new turn execution updates.", "x-data-class": "public" },
    "include_snapshot": { "type": "boolean", "description": "Whether to include an initial turn execution snapshot event before live updates.", "x-data-class": "public" }
  }
}
