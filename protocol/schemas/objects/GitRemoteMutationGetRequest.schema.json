{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitRemoteMutationGetRequest.schema.json",
  "title": "GitRemoteMutationGetRequest",
  "description": "Get request for prepared git remote mutation by stable prepared identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 4,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "prepared_mutation_id"
  ],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.GitRemoteMutationGetRequest", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable request correlation identifier.",
      "x-data-class": "public"
    },
    "prepared_mutation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Prepared mutation identifier to fetch.",
      "x-data-class": "public"
    }
  }
}
