{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadSecretAccess.schema.json",
  "title": "ActionPayloadSecretAccess",
  "description": "Typed action payload for secrets lease access operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 8,
  "required": [
    "schema_id",
    "schema_version",
    "secret_ref",
    "access_mode"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadSecretAccess",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "secret_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Canonical secret reference being requested.",
      "x-data-class": "sensitive"
    },
    "access_mode": {
      "type": "string",
      "enum": [
        "lease_issue",
        "lease_renew"
      ],
      "description": "Secret lease access mode.",
      "x-data-class": "public"
    },
    "lease_ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400,
      "description": "Requested lease TTL in seconds.",
      "x-data-class": "public"
    },
    "justification": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Human-readable reason for secret access.",
      "x-data-class": "sensitive"
    },
    "requires_egress": {
      "type": "boolean",
      "description": "Whether secret access implies network egress coupling.",
      "x-data-class": "public"
    },
    "target_system": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Target system profile using the secret lease.",
      "x-data-class": "public"
    }
  }
}
