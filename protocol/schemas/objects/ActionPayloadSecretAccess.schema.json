{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ActionPayloadSecretAccess.schema.json",
  "title": "ActionPayloadSecretAccess",
  "description": "Typed action payload for secrets lease access operations.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": [
    "schema_id",
    "schema_version",
    "access_mode"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.ActionPayloadSecretAccess",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "access_mode": {
      "type": "string",
      "enum": [
        "lease_issue",
        "lease_renew",
        "lease_revoke"
      ],
      "description": "Secret lease access mode.",
      "x-data-class": "public"
    },
    "secret_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^secrets/[A-Za-z0-9._/-]+$",
      "description": "Canonical secret reference being requested. Required for lease issue and may be included for renew/revoke traceability.",
      "x-data-class": "sensitive"
    },
    "lease_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable existing lease identity required for renew/revoke operations.",
      "x-data-class": "public"
    },
    "lease_ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600,
      "description": "Requested lease TTL in seconds. When omitted for lease_issue, secretsd defaults to 900 seconds. Requested TTLs are advisory and enforced by the lease hard cap.",
      "x-data-class": "public"
    },
    "renewal_context": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 3,
      "description": "Renewal context that must match the existing lease binding and currently valid policy context.",
      "x-data-class": "public",
      "required": [
        "consumer_principal_ref",
        "target_ref",
        "policy_context_hash"
      ],
      "properties": {
        "consumer_principal_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Consumer principal expected to match the existing lease consumer binding.",
          "x-data-class": "public"
        },
        "target_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Target scope expected to match the existing lease target binding.",
          "x-data-class": "public"
        },
        "policy_context_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Current policy context digest expected to match the lease renewal policy binding.",
          "x-data-class": "public"
        }
      }
    },
    "justification": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Human-readable reason for secret access.",
      "x-data-class": "sensitive"
    },
    "requires_egress": {
      "type": "boolean",
      "description": "Whether secret access implies network egress coupling.",
      "x-data-class": "public"
    },
    "target_system": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Target system profile using the secret lease.",
      "x-data-class": "public"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "access_mode": {
            "const": "lease_issue",
            "description": "Conditional branch for lease issue payload validation.",
            "x-data-class": "public"
          }
        },
        "required": ["access_mode"]
      },
      "then": {
        "required": ["secret_ref"]
      }
    },
    {
      "if": {
        "properties": {
          "access_mode": {
            "const": "lease_renew",
            "description": "Conditional branch for lease renew payload validation.",
            "x-data-class": "public"
          }
        },
        "required": ["access_mode"]
      },
      "then": {
        "required": [
          "lease_id",
          "renewal_context"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "access_mode": {
            "const": "lease_revoke",
            "description": "Conditional branch for lease revoke payload validation.",
            "x-data-class": "public"
          }
        },
        "required": ["access_mode"]
      },
      "then": {
        "required": ["lease_id"]
      }
    },
    {
      "if": {
        "properties": {
          "access_mode": {
            "const": "lease_revoke",
            "description": "Conditional branch for lease revoke payload validation.",
            "x-data-class": "public"
          }
        },
        "required": ["access_mode"]
      },
      "then": {
        "properties": {
          "lease_ttl_seconds": {
            "not": {},
            "description": "lease_revoke operations must not include TTL extension requests.",
            "x-data-class": "public"
          }
        }
      }
    }
  ]
}
