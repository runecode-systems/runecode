{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ApprovalBlockedWorkScope.schema.json",
  "title": "ApprovalBlockedWorkScope",
  "description": "Typed scope descriptor for the work currently blocked pending approval.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 9,
  "required": ["schema_id", "schema_version", "scope_kind", "action_kind"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ApprovalBlockedWorkScope", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "scope_kind": { "type": "string", "enum": ["workspace", "run", "stage", "step", "action_kind"], "description": "Most specific scope level blocked by this pending approval.", "x-data-class": "public" },
    "workspace_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound workspace identifier when available.", "x-data-class": "public" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound run identifier when available.", "x-data-class": "public" },
    "stage_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound stage identifier when available.", "x-data-class": "public" },
    "step_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound step identifier when available.", "x-data-class": "public" },
    "role_instance_id": { "type": "string", "minLength": 1, "maxLength": 128, "description": "Bound role instance identifier when available.", "x-data-class": "public" },
    "action_kind": { "type": "string", "enum": ["workspace_write", "executor_run", "artifact_read", "promotion", "gateway_egress", "dependency_fetch", "backend_posture_change", "action_gate_override", "stage_summary_sign_off", "secret_access"], "description": "Bound action kind tied to the blocked work.", "x-data-class": "public" }
  }
}
