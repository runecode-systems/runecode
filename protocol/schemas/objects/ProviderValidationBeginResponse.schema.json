{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProviderValidationBeginResponse.schema.json",
  "title": "ProviderValidationBeginResponse",
  "description": "Typed response after broker-owned validation lifecycle enters in-progress state.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 7,
  "required": ["schema_id", "schema_version", "request_id", "provider_profile_id", "validation_attempt_id", "setup_session", "profile"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProviderValidationBeginResponse", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Stable request correlation identifier.", "x-data-class": "public" },
    "provider_profile_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Provider profile identifier being validated.", "x-data-class": "public" },
    "validation_attempt_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$", "description": "Validation attempt identity authoritative for commit.", "x-data-class": "public" },
    "setup_session": { "$ref": "ProviderSetupSession.schema.json", "description": "Updated setup-session lifecycle posture.", "x-data-class": "public" },
    "profile": { "$ref": "ProviderProfile.schema.json", "description": "Projected provider profile posture after validation begin.", "x-data-class": "public" }
  }
}
