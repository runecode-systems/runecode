{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/ProjectSubstrateUpgradePreview.schema.json",
  "title": "ProjectSubstrateUpgradePreview",
  "description": "Explicit preview contract for canonical project-substrate upgrade and remediation lifecycle.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 11,
  "required": ["schema_id", "schema_version", "repository_root", "status", "current_snapshot", "expected_snapshot", "preview_digest"],
  "properties": {
    "schema_id": { "const": "runecode.protocol.v0.ProjectSubstrateUpgradePreview", "description": "Protocol schema identifier.", "x-data-class": "public" },
    "schema_version": { "const": "0.1.0", "description": "Protocol schema version.", "x-data-class": "public" },
    "repository_root": { "type": "string", "minLength": 1, "maxLength": 4096, "description": "Authoritative repository root for upgrade preview.", "x-data-class": "public" },
    "status": { "type": "string", "enum": ["noop", "ready_for_apply", "blocked_remediation_only"], "description": "Upgrade preview status.", "x-data-class": "public" },
    "reason_codes": {
      "type": "array",
      "maxItems": 32,
      "description": "Stable reason codes describing upgrade advisories or remediation blocks.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Deterministic reason code.", "x-data-class": "public" }
    },
    "current_snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Current discovered project substrate snapshot.", "x-data-class": "public" },
    "expected_snapshot": { "$ref": "ProjectSubstrateValidationSnapshot.schema.json", "description": "Expected snapshot after successful upgrade apply.", "x-data-class": "public" },
    "file_changes": {
      "type": "array",
      "maxItems": 32,
      "description": "Previewed canonical file changes for upgrade.",
      "x-data-class": "public",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "maxProperties": 4,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 512, "description": "Repository-relative path.", "x-data-class": "public" },
          "action": { "type": "string", "enum": ["update"], "description": "Planned upgrade change action.", "x-data-class": "public" },
          "before_content_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Optional pre-upgrade content digest.", "x-data-class": "public" },
          "after_content_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Optional post-upgrade content digest.", "x-data-class": "public" }
        }
      }
    },
    "preconditions": {
      "type": "array",
      "maxItems": 32,
      "description": "Deterministic precondition checks evaluated before upgrade apply.",
      "x-data-class": "public",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "maxProperties": 2,
        "required": ["code", "satisfied"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Stable precondition code.", "x-data-class": "public" },
          "satisfied": { "type": "boolean", "description": "Whether the precondition is currently satisfied.", "x-data-class": "public" }
        }
      }
    },
    "required_follow_up": {
      "type": "array",
      "maxItems": 32,
      "description": "Stable follow-up guidance codes projected by broker-owned upgrade/remediation contracts.",
      "x-data-class": "public",
      "items": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9_]+$", "description": "Required follow-up guidance code.", "x-data-class": "public" }
    },
    "preview_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "maxLength": 71, "description": "Deterministic preview digest that must match apply intent.", "x-data-class": "public" }
  }
}
