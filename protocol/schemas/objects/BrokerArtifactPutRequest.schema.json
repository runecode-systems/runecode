{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/BrokerArtifactPutRequest.schema.json",
  "title": "BrokerArtifactPutRequest",
  "description": "Typed broker artifact-put request family for JSON transport binding with base64 payload.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 10,
  "required": [
    "schema_id",
    "schema_version",
    "request_id",
    "payload_base64",
    "content_type",
    "data_class",
    "provenance_receipt_hash"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.BrokerArtifactPutRequest",
      "description": "Stable protocol object-family identifier for artifact put requests.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Exact protocol schema version used to validate this artifact put request.",
      "x-data-class": "public"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable client-provided request identifier echoed by all responses.",
      "x-data-class": "public"
    },
    "payload_base64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1398104,
      "contentEncoding": "base64",
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "description": "Base64-encoded artifact bytes. Runtime enforces decoded size limits.",
      "x-data-class": "sensitive"
    },
    "content_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Artifact content type metadata.",
      "x-data-class": "public"
    },
    "data_class": {
      "type": "string",
      "enum": [
        "spec_text",
        "unapproved_file_excerpts",
        "approved_file_excerpts",
        "diffs",
        "build_logs",
        "audit_events",
        "audit_verification_report",
        "audit_receipt_export_copy",
        "gate_evidence",
        "dependency_batch_manifest",
        "dependency_resolved_unit_manifest",
        "dependency_resolved_payload",
        "dependency_materialized_tree",
        "web_query",
        "web_citations"
      ],
      "description": "Artifact data classification constrained to the shared protocol vocabulary.",
      "x-data-class": "public"
    },
    "provenance_receipt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "maxLength": 71,
      "description": "Provenance receipt digest bound to the artifact bytes.",
      "x-data-class": "public"
    },
    "created_by_role": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional producer role identity metadata.",
      "x-data-class": "public"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional run identifier metadata.",
      "x-data-class": "public"
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional step identifier metadata.",
      "x-data-class": "public"
    }
  }
}
