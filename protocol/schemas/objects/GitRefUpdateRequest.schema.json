{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/GitRefUpdateRequest.schema.json",
  "title": "GitRefUpdateRequest",
  "description": "Provider-neutral typed git ref-update request bound to repository identity, expected old ref state, patch artifacts, and expected result tree identity.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 13,
  "required": [
    "schema_id",
    "schema_version",
    "request_kind",
    "repository_identity",
    "target_ref",
    "expected_old_ref_hash",
    "referenced_patch_artifact_digests",
    "commit_intent",
    "expected_result_tree_hash",
    "allow_force_push",
    "allow_ref_deletion"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.GitRefUpdateRequest",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "request_kind": {
      "type": "string",
      "enum": [
        "git_ref_update"
      ],
      "description": "Provider-neutral git request family.",
      "x-data-class": "public"
    },
    "repository_identity": {
      "$ref": "DestinationDescriptor.schema.json",
      "description": "Logical repository identity bound for this request.",
      "x-data-class": "public"
    },
    "target_ref": {
      "type": "string",
      "minLength": 6,
      "maxLength": 256,
      "pattern": "^refs/[A-Za-z0-9._/-]+$",
      "description": "Canonical target ref to update; branches and tags both use this same typed contract.",
      "x-data-class": "public"
    },
    "expected_old_ref_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Expected old ref target hash used for fail-closed remote drift checks.",
      "x-data-class": "public"
    },
    "referenced_patch_artifact_digests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "description": "Signed patch artifact digests consumed by this request.",
      "x-data-class": "public",
      "items": {
        "$ref": "Digest.schema.json#/$defs/digestValue"
      }
    },
    "commit_intent": {
      "$ref": "GitCommitIntent.schema.json",
      "description": "Typed commit substep intent bound into remote mutation.",
      "x-data-class": "public"
    },
    "expected_result_tree_hash": {
      "$ref": "Digest.schema.json#/$defs/digestValue",
      "description": "Expected tree hash after applying referenced patch artifact(s).",
      "x-data-class": "public"
    },
    "allow_force_push": {
      "const": false,
      "description": "Destructive/non-fast-forward ref updates are denied by default in v1.",
      "x-data-class": "public"
    },
    "allow_ref_deletion": {
      "const": false,
      "description": "Ref deletion is denied by default in v1.",
      "x-data-class": "public"
    },
    "ref_purpose": {
      "type": "string",
      "enum": [
        "branch",
        "tag"
      ],
      "description": "Optional typed classification for target ref use.",
      "x-data-class": "public"
    },
    "base_ref": {
      "type": "string",
      "minLength": 6,
      "maxLength": 256,
      "pattern": "^refs/[A-Za-z0-9._/-]+$",
      "description": "Optional related base ref for merge-aware workflows.",
      "x-data-class": "public"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "repository_identity": {
            "type": "object",
            "properties": {
              "descriptor_kind": {
                "const": "git_remote"
              }
            },
            "required": [
              "descriptor_kind"
            ]
          }
        },
        "required": [
          "repository_identity"
        ]
      },
      "then": true,
      "else": {
        "not": {}
      }
    }
  ]
}
