{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runecode.dev/protocol/schemas/objects/SecretLease.schema.json",
  "title": "SecretLease",
  "description": "Typed lease contract for persisted secret access and future short-lived derived token access.",
  "type": "object",
  "additionalProperties": false,
  "maxProperties": 12,
  "required": [
    "schema_id",
    "schema_version",
    "lease_id",
    "lease_kind",
    "lease_subject",
    "consumer_binding",
    "target_binding",
    "delivery_binding",
    "action_policy_binding",
    "lifecycle",
    "revocation",
    "durable_state"
  ],
  "properties": {
    "schema_id": {
      "const": "runecode.protocol.v0.SecretLease",
      "description": "Protocol schema identifier.",
      "x-data-class": "public"
    },
    "schema_version": {
      "const": "0.1.0",
      "description": "Protocol schema version.",
      "x-data-class": "public"
    },
    "lease_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable canonical lease identity.",
      "x-data-class": "public"
    },
    "lease_kind": {
      "type": "string",
      "enum": [
        "persisted_secret",
        "derived_token"
      ],
      "description": "Lease family kind covering persisted secrets and future short-lived derived tokens.",
      "x-data-class": "public"
    },
    "lease_subject": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 3,
      "description": "Bound subject identity for this lease.",
      "x-data-class": "public",
      "required": [
        "subject_ref"
      ],
      "properties": {
        "subject_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^(secrets|tokens)/[A-Za-z0-9._/-]+$",
          "description": "Canonical subject reference (for example a secret_ref or derived-token ref).",
          "x-data-class": "sensitive"
        },
        "source_lease_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Source lease identity when the subject is a derived token.",
          "x-data-class": "public"
        },
        "issuer_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Trusted issuer identity for the lease subject.",
          "x-data-class": "public"
        }
      }
    },
    "consumer_binding": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "description": "Bound consumer identity and role posture allowed to consume this lease.",
      "x-data-class": "public",
      "required": [
        "consumer_principal_ref",
        "role_family",
        "role_kind"
      ],
      "properties": {
        "consumer_principal_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Stable consumer principal identity reference.",
          "x-data-class": "public"
        },
        "role_family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Bound role family for lease consumption.",
          "x-data-class": "public"
        },
        "role_kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Bound role kind for lease consumption.",
          "x-data-class": "public"
        },
        "session_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Optional session binding used for per-session attribution and fail-closed replay protection.",
          "x-data-class": "public"
        }
      }
    },
    "target_binding": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "description": "Destination or target binding scope for lease use.",
      "x-data-class": "public",
      "required": [
        "target_kind",
        "target_ref"
      ],
      "properties": {
        "target_kind": {
          "type": "string",
          "enum": [
            "destination_ref",
            "local_target"
          ],
          "description": "Target binding kind for lease use.",
          "x-data-class": "public"
        },
        "target_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Canonical bound destination_ref or trusted local target reference.",
          "x-data-class": "public"
        }
      }
    },
    "delivery_binding": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 4,
      "description": "Trusted local lease-material retrieval binding by canonical lease identity.",
      "x-data-class": "public",
      "required": [
        "retrieval_path_kind",
        "lease_identity_field",
        "consumer_binding_enforced",
        "bridge_handoff_posture"
      ],
      "properties": {
        "retrieval_path_kind": {
          "type": "string",
          "enum": [
            "secretsd_trusted_local"
          ],
          "description": "Secret material retrieval stays on trusted local secretsd channels.",
          "x-data-class": "public"
        },
        "lease_identity_field": {
          "type": "string",
          "const": "lease_id",
          "description": "Retrieval path uses canonical lease identity rather than raw secret material handoff.",
          "x-data-class": "public"
        },
        "consumer_binding_enforced": {
          "type": "boolean",
          "const": true,
          "description": "Retrieval requires consumer principal binding to match lease consumer_binding.",
          "x-data-class": "public"
        },
        "bridge_handoff_posture": {
          "type": "string",
          "enum": [
            "lease_boundary_only"
          ],
          "description": "Downstream bridge/runtime integrations must consume material via lease boundary semantics.",
          "x-data-class": "public"
        }
      }
    },
    "action_policy_binding": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 5,
      "description": "Action, policy, and audit bindings that authorize and trace this lease.",
      "x-data-class": "public",
      "required": [
        "action_kind",
        "policy_context_hash",
        "policy_binding_hash",
        "action_request_hash"
      ],
      "properties": {
        "action_kind": {
          "type": "string",
          "const": "secret_access",
          "description": "Action kind that authorized this lease.",
          "x-data-class": "public"
        },
        "policy_context_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Canonical policy context digest bound into the lease.",
          "x-data-class": "public"
        },
        "policy_binding_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest binding the lease to the evaluated policy payload.",
          "x-data-class": "public"
        },
        "action_request_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Digest of the action request that created or renewed this lease.",
          "x-data-class": "public"
        },
        "audit_binding_hash": {
          "$ref": "Digest.schema.json#/$defs/digestValue",
          "description": "Optional digest linking the lease to an auditable lifecycle record.",
          "x-data-class": "public"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 7,
      "description": "Lease lifecycle and renewal posture state.",
      "x-data-class": "public",
      "required": [
        "issued_at",
        "expires_at",
        "effective_ttl_seconds",
        "lease_mode",
        "renewal_allowed"
      ],
      "properties": {
        "issued_at": {
          "type": "string",
          "maxLength": 64,
          "format": "date-time",
          "description": "Lease issue timestamp.",
          "x-data-class": "public"
        },
        "expires_at": {
          "type": "string",
          "maxLength": 64,
          "format": "date-time",
          "description": "Lease expiry timestamp.",
          "x-data-class": "public"
        },
        "effective_ttl_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600,
          "description": "Effective lease TTL enforced by secretsd after applying defaults and hard caps.",
          "x-data-class": "public"
        },
        "lease_mode": {
          "type": "string",
          "enum": [
            "read",
            "use"
          ],
          "description": "Lease usage mode.",
          "x-data-class": "public"
        },
        "renewal_allowed": {
          "type": "boolean",
          "description": "Whether this lease may be renewed.",
          "x-data-class": "public"
        },
        "last_renewed_at": {
          "type": "string",
          "maxLength": 64,
          "format": "date-time",
          "description": "Last renewal timestamp.",
          "x-data-class": "public"
        },
        "renewal_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of successful renewals for this lease identity.",
          "x-data-class": "public"
        }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 5,
      "description": "Durable revocation state bound to lease identity.",
      "x-data-class": "public",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "active",
            "revoked"
          ],
          "description": "Revocation state for this lease identity.",
          "x-data-class": "public"
        },
        "revoked_at": {
          "type": "string",
          "maxLength": 64,
          "format": "date-time",
          "description": "Timestamp of durable revocation.",
          "x-data-class": "public"
        },
        "revoked_by": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Principal reference that issued the revocation.",
          "x-data-class": "public"
        },
        "revocation_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "description": "Revocation reason captured for audit traceability.",
          "x-data-class": "sensitive"
        },
        "revocation_persisted": {
          "type": "boolean",
          "description": "Whether the revocation outcome was durably persisted for fail-closed restart recovery.",
          "x-data-class": "public"
        }
      }
    },
    "durable_state": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 3,
      "description": "Durable lifecycle state required to preserve deny, expiry, and revocation outcomes across restart.",
      "x-data-class": "public",
      "required": [
        "state_persisted",
        "deny_outcomes_preserved",
        "expiry_indexed"
      ],
      "properties": {
        "state_persisted": {
          "type": "boolean",
          "description": "Whether the lease lifecycle state is durably persisted.",
          "x-data-class": "public"
        },
        "deny_outcomes_preserved": {
          "type": "boolean",
          "description": "Whether prior deny outcomes tied to this lease identity are preserved fail closed.",
          "x-data-class": "public"
        },
        "expiry_indexed": {
          "type": "boolean",
          "description": "Whether expiry state is indexed durably for restart-safe expiry enforcement.",
          "x-data-class": "public"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lease_kind": {
            "const": "derived_token",
            "description": "Conditional branch for derived-token lease subjects.",
            "x-data-class": "public"
          }
        },
        "required": ["lease_kind"]
      },
      "then": {
        "properties": {
          "lease_subject": {
            "required": [
              "subject_ref",
              "source_lease_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "revocation": {
            "properties": {
              "status": {
                "const": "revoked",
                "description": "Conditional branch for revoked leases.",
                "x-data-class": "public"
              }
            },
            "required": ["status"]
          }
        },
        "required": ["revocation"]
      },
      "then": {
        "properties": {
          "revocation": {
            "required": [
              "status",
              "revoked_at",
              "revoked_by",
              "revocation_reason",
              "revocation_persisted"
            ]
          },
          "durable_state": {
            "required": [
              "state_persisted",
              "deny_outcomes_preserved",
              "expiry_indexed"
            ],
            "properties": {
              "state_persisted": {
                "const": true
              },
              "deny_outcomes_preserved": {
                "const": true
              },
              "expiry_indexed": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "revocation": {
            "properties": {
              "status": {
                "const": "active",
                "description": "Conditional branch for active leases.",
                "x-data-class": "public"
              }
            },
            "required": ["status"]
          }
        },
        "required": ["revocation"]
      },
      "then": {
        "properties": {
          "durable_state": {
            "required": [
              "state_persisted",
              "deny_outcomes_preserved",
              "expiry_indexed"
            ],
            "properties": {
              "state_persisted": {
                "const": true
              },
              "deny_outcomes_preserved": {
                "const": true
              },
              "expiry_indexed": {
                "const": true
              }
            }
          }
        }
      }
    }
  ]
}
