{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
